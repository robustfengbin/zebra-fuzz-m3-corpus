  298|      0|                                    None => Err(InvalidDerEncoding::InvalidComponent {
  299|      0|                                        name: "r",
  300|      0|                                        value: r_s.to_vec(),
  301|      0|                                        error: InvalidDerInteger::IncorrectLength {
  302|      0|                                            actual: r_s.len(),
  303|      0|                                            expected: *r_len,
  304|      0|                                        },
  305|      0|                                    }),
  306|      0|                                    Some((r, s)) => Self::is_valid_integer(r)
  307|      0|                                        .map_err(|error| InvalidDerEncoding::InvalidComponent {
  308|       |                                            name: "r",
