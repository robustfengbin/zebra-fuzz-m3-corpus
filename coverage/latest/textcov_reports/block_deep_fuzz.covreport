  341|  78.6k|    expected_block_subsidy: Amount<NonNegative>,
  342|  78.6k|) -> Result<HashMap<FundingStreamReceiver, Amount<NonNegative>>, amount::Error> {
  343|  78.6k|    let mut results = HashMap::new();
