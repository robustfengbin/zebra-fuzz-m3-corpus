  591|  95.5k|    fn from_repr(repr: Self::Repr) -> CtOption<Self> {
  592|  95.5k|        let mut tmp = Fp([0, 0, 0, 0]);
  593|       |
  594|  95.5k|        tmp.0[0] = u64::from_le_bytes(repr[0..8].try_into().unwrap());
  595|  95.5k|        tmp.0[1] = u64::from_le_bytes(repr[8..16].try_into().unwrap());
  596|  95.5k|        tmp.0[2] = u64::from_le_bytes(repr[16..24].try_into().unwrap());
  597|  95.5k|        tmp.0[3] = u64::from_le_bytes(repr[24..32].try_into().unwrap());
  598|       |
  599|       |        // Try to subtract the modulus
  600|  95.5k|        let (_, borrow) = sbb(tmp.0[0], MODULUS.0[0], 0);
  601|  95.5k|        let (_, borrow) = sbb(tmp.0[1], MODULUS.0[1], borrow);
  602|  95.5k|        let (_, borrow) = sbb(tmp.0[2], MODULUS.0[2], borrow);
  603|  95.5k|        let (_, borrow) = sbb(tmp.0[3], MODULUS.0[3], borrow);
  604|       |
  605|       |        // If the element is smaller than MODULUS then the
  606|       |        // subtraction will underflow, producing a borrow value
  607|       |        // of 0xffff...ffff. Otherwise, it'll be zero.
  608|  95.5k|        let is_some = (borrow as u8) & 1;
  609|       |
  610|       |        // Convert to Montgomery form by computing
  611|       |        // (a.R^0 * R^2) / R = a.R
  612|  95.5k|        tmp *= &R2;
  613|       |
  614|  95.5k|        CtOption::new(tmp, Choice::from(is_some))
  615|  95.5k|    }
