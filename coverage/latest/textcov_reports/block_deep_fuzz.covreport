_RNvMsa_NtCsjpkeS12E7YP_9bls12_3816scalarNtB5_6Scalar3subCs3VjbIwwZMBL_6jubjub:
  582|  31.6M|    pub const fn sub(&self, rhs: &Self) -> Self {
  583|  31.6M|        let (d0, borrow) = sbb(self.0[0], rhs.0[0], 0);
  584|  31.6M|        let (d1, borrow) = sbb(self.0[1], rhs.0[1], borrow);
  585|  31.6M|        let (d2, borrow) = sbb(self.0[2], rhs.0[2], borrow);
  586|  31.6M|        let (d3, borrow) = sbb(self.0[3], rhs.0[3], borrow);
  587|       |
  588|       |        // If underflow occurred on the final limb, borrow = 0xfff...fff, otherwise
  589|       |        // borrow = 0x000...000. Thus, we use it as a mask to conditionally add the modulus.
  590|  31.6M|        let (d0, carry) = adc(d0, MODULUS.0[0] & borrow, 0);
  591|  31.6M|        let (d1, carry) = adc(d1, MODULUS.0[1] & borrow, carry);
  592|  31.6M|        let (d2, carry) = adc(d2, MODULUS.0[2] & borrow, carry);
  593|  31.6M|        let (d3, _) = adc(d3, MODULUS.0[3] & borrow, carry);
  594|       |
  595|  31.6M|        Scalar([d0, d1, d2, d3])
  596|  31.6M|    }
