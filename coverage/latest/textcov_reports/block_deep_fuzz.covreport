  235|       |            // https://zips.z.cash/protocol/protocol.pdf#concretesym but fixed to
  236|       |            // 601 bytes in https://zips.z.cash/protocol/protocol.pdf#joinsplitencodingandconsensus
  237|       |            // See [`note::EncryptedNote::zcash_deserialize`].
  238|       |            enc_ciphertexts: [
