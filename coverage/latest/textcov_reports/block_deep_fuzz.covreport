  600|  8.22M|    pub const fn add(&self, rhs: &Self) -> Self {
  601|  8.22M|        let (d0, carry) = adc(self.0[0], rhs.0[0], 0);
  602|  8.22M|        let (d1, carry) = adc(self.0[1], rhs.0[1], carry);
  603|  8.22M|        let (d2, carry) = adc(self.0[2], rhs.0[2], carry);
  604|  8.22M|        let (d3, _) = adc(self.0[3], rhs.0[3], carry);
  605|       |
  606|       |        // Attempt to subtract the modulus, to ensure the value
  607|       |        // is smaller than the modulus.
  608|  8.22M|        (&Scalar([d0, d1, d2, d3])).sub(&MODULUS)
  609|  8.22M|    }
