   81|  9.08k|pub fn iso_map<F: Field, C: CurveExt<Base = F>, I: CurveExt<Base = F>>(
   82|  9.08k|    p: &I,
   83|  9.08k|    iso: &[C::Base; 13],
   84|  9.08k|) -> C {
   85|       |    // The input and output are in Jacobian coordinates, using the method
   86|       |    // in "Avoiding inversions" [WB2019, section 4.3].
