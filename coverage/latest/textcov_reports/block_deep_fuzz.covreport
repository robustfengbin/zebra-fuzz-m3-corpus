  620|  15.8M|    pub const fn sub(&self, rhs: &Self) -> Self {
  621|  15.8M|        let (d0, borrow) = sbb(self.0[0], rhs.0[0], 0);
  622|  15.8M|        let (d1, borrow) = sbb(self.0[1], rhs.0[1], borrow);
  623|  15.8M|        let (d2, borrow) = sbb(self.0[2], rhs.0[2], borrow);
  624|  15.8M|        let (d3, borrow) = sbb(self.0[3], rhs.0[3], borrow);
  625|       |
