   62|       |    // bytes are; we don't validate them yet — the oracle below catches any non-canonical input.
   63|  3.81k|    let (h, len): (i64, usize) = match *script_sig
   64|  3.81k|        .first()
   65|  3.81k|        .ok_or(parse_err("Empty coinbase script"))?
   66|       |    {
   67|     77|        op_n @ 0x51..=0x60 => (i64::from(op_n - 0x50), 1),
   68|  3.75k|        n @ 1..=5 => {
   69|  3.73k|            let bytes = script_sig
   70|  3.73k|                .get(1..=usize::from(n))
   71|  3.73k|                .ok_or(parse_err("Coinbase height push truncated"))?;
   72|       |            // Permissive read: zero-extend the wire bytes into an i64. The candidate is only
   73|       |            // trusted after the canonical-encode-and-compare check below.
   74|  3.73k|            let mut buf = [0u8; 8];
   75|  3.73k|            buf[..bytes.len()].copy_from_slice(bytes);
   76|  3.73k|            (i64::from_le_bytes(buf), 1 + bytes.len())
   77|       |        }
   78|     21|        _ => return Err(parse_err("Invalid coinbase script prefix")),
   79|       |    };
   80|       |
   81|       |    // Oracle: re-encode the candidate the way zcash_transparent's coinbase builder does, and
   82|       |    // require byte-exact equality.
   83|  3.79k|    if script_sig
   84|  3.79k|        .get(..len)
   85|  3.79k|        .ok_or(parse_err("Coinbase script too short"))?
   86|  3.79k|        != pattern::push_num(h).to_bytes().as_slice()
   87|       |    {
   88|     37|        return Err(parse_err("Non-canonical coinbase height encoding"));
   89|  3.75k|    }
   90|       |
   91|  3.75k|    let h = u32::try_from(h).map_err(|_| parse_err("Negative coinbase height"))?;
   92|  3.75k|    let height =
   93|  3.75k|        Height::try_from(h).map_err(|_| parse_err("Coinbase height exceeds Height::MAX"))?;
   94|       |
   95|  3.75k|    Ok((height, script_sig[len..].to_vec()))
