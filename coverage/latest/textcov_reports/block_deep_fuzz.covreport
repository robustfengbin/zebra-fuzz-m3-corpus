_RNvXsk_NtNtCs41Au54XfBWR_12pasta_curves6fields2fpNtB5_2FpNtNtNtB9_10arithmetic6fields16SqrtTableHelpers21pow_by_t_minus1_over2:
  692|  69.6k|    fn pow_by_t_minus1_over2(&self) -> Self {
  693|  69.6k|        let sqr = |x: Fp, i: u32| (0..i).fold(x, |x, _| x.square());
  694|       |
  695|  69.6k|        let r10 = self.square();
  696|  69.6k|        let r11 = r10 * self;
  697|  69.6k|        let r110 = r11.square();
  698|  69.6k|        let r111 = r110 * self;
  699|  69.6k|        let r1001 = r111 * r10;
  700|  69.6k|        let r1101 = r111 * r110;
  701|  69.6k|        let ra = sqr(*self, 129) * self;
  702|  69.6k|        let rb = sqr(ra, 7) * r1001;
  703|  69.6k|        let rc = sqr(rb, 7) * r1101;
  704|  69.6k|        let rd = sqr(rc, 4) * r11;
  705|  69.6k|        let re = sqr(rd, 6) * r111;
  706|  69.6k|        let rf = sqr(re, 3) * r111;
  707|  69.6k|        let rg = sqr(rf, 10) * r1001;
  708|  69.6k|        let rh = sqr(rg, 5) * r1001;
  709|  69.6k|        let ri = sqr(rh, 4) * r1001;
  710|  69.6k|        let rj = sqr(ri, 3) * r111;
  711|  69.6k|        let rk = sqr(rj, 4) * r1001;
  712|  69.6k|        let rl = sqr(rk, 5) * r11;
  713|  69.6k|        let rm = sqr(rl, 4) * r111;
  714|  69.6k|        let rn = sqr(rm, 4) * r11;
  715|  69.6k|        let ro = sqr(rn, 6) * r1001;
  716|  69.6k|        let rp = sqr(ro, 5) * r1101;
  717|  69.6k|        let rq = sqr(rp, 4) * r11;
  718|  69.6k|        let rr = sqr(rq, 7) * r111;
  719|  69.6k|        let rs = sqr(rr, 3) * r11;
  720|  69.6k|        rs.square() // rt
  721|  69.6k|    }
