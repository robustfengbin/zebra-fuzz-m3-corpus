  651|  1.33M|    pub const fn neg(&self) -> Self {
  652|       |        // Subtract `self` from `MODULUS` to negate. Ignore the final
  653|       |        // borrow because it cannot underflow; self is guaranteed to
  654|       |        // be in the field.
  655|  1.33M|        let (d0, borrow) = sbb(MODULUS.0[0], self.0[0], 0);
  656|  1.33M|        let (d1, borrow) = sbb(MODULUS.0[1], self.0[1], borrow);
  657|  1.33M|        let (d2, borrow) = sbb(MODULUS.0[2], self.0[2], borrow);
  658|  1.33M|        let (d3, _) = sbb(MODULUS.0[3], self.0[3], borrow);
  659|       |
