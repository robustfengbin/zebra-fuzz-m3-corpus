  544|  46.3k|    const fn montgomery_reduce(
  545|  46.3k|        r0: u64,
  546|  46.3k|        r1: u64,
  547|  46.3k|        r2: u64,
  548|  46.3k|        r3: u64,
  549|  46.3k|        r4: u64,
  550|  46.3k|        r5: u64,
  551|  46.3k|        r6: u64,
  552|  46.3k|        r7: u64,
  553|  46.3k|    ) -> Self {
  554|       |        // The Montgomery reduction here is based on Algorithm 14.32 in
  555|       |        // Handbook of Applied Cryptography
  556|       |        // <http://cacr.uwaterloo.ca/hac/about/chap14.pdf>.
  557|       |
  558|  46.3k|        let k = r0.wrapping_mul(INV);
  559|  46.3k|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  560|  46.3k|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  561|  46.3k|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  562|  46.3k|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  563|  46.3k|        let (r4, carry2) = adc(r4, 0, carry);
  564|       |
  565|  46.3k|        let k = r1.wrapping_mul(INV);
  566|  46.3k|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  567|  46.3k|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  568|  46.3k|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  569|  46.3k|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  570|  46.3k|        let (r5, carry2) = adc(r5, carry2, carry);
  571|       |
  572|  46.3k|        let k = r2.wrapping_mul(INV);
  573|  46.3k|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  574|  46.3k|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  575|  46.3k|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  576|  46.3k|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  577|  46.3k|        let (r6, carry2) = adc(r6, carry2, carry);
  578|       |
  579|  46.3k|        let k = r3.wrapping_mul(INV);
  580|  46.3k|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  581|  46.3k|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  582|  46.3k|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  583|  46.3k|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  584|  46.3k|        let (r7, _) = adc(r7, carry2, carry);
  585|       |
  586|       |        // Result may be within MODULUS of the correct value
  587|  46.3k|        (&Fr([r4, r5, r6, r7])).sub(&MODULUS)
  588|  46.3k|    }
