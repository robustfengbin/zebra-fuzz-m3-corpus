_RINvNtCs41Au54XfBWR_12pasta_curves11hashtocurve13hash_to_fieldNtNtNtB4_6fields2fp2FpEB4_:
   11|  9.08k|pub fn hash_to_field<F: FromUniformBytes<64>>(
   12|  9.08k|    curve_id: &str,
   13|  9.08k|    domain_prefix: &str,
   14|  9.08k|    message: &[u8],
   15|  9.08k|    buf: &mut [F; 2],
   16|  9.08k|) {
   17|  9.08k|    assert!(domain_prefix.len() < 256);
   18|  9.08k|    assert!((22 + curve_id.len() + domain_prefix.len()) < 256);
   19|       |
   20|       |    // Assume that the field size is 32 bytes and k is 256, where k is defined in
   21|       |    // <https://www.ietf.org/archive/id/draft-irtf-cfrg-hash-to-curve-10.html#name-security-considerations-3>.
   22|       |    const CHUNKLEN: usize = 64;
   23|       |    const_assert!(CHUNKLEN * 2 < 256);
   24|       |
   25|       |    // Input block size of BLAKE2b.
   26|       |    const R_IN_BYTES: usize = 128;
   27|       |
   28|  9.08k|    let personal = [0u8; 16];
   29|  9.08k|    let empty_hasher = blake2b_simd::Params::new()
   30|  9.08k|        .hash_length(CHUNKLEN)
   31|  9.08k|        .personal(&personal)
   32|  9.08k|        .to_state();
   33|       |
   34|  9.08k|    let b_0 = empty_hasher
   35|  9.08k|        .clone()
   36|  9.08k|        .update(&[0; R_IN_BYTES])
   37|  9.08k|        .update(message)
   38|  9.08k|        .update(&[0, (CHUNKLEN * 2) as u8, 0])
   39|  9.08k|        .update(domain_prefix.as_bytes())
   40|  9.08k|        .update(b"-")
   41|  9.08k|        .update(curve_id.as_bytes())
   42|  9.08k|        .update(b"_XMD:BLAKE2b_SSWU_RO_")
   43|  9.08k|        .update(&[(22 + curve_id.len() + domain_prefix.len()) as u8])
   44|  9.08k|        .finalize();
   45|       |
   46|  9.08k|    let b_1 = empty_hasher
   47|  9.08k|        .clone()
   48|  9.08k|        .update(b_0.as_array())
