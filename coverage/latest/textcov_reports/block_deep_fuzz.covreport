_RNvMsa_NtCsjpkeS12E7YP_9bls12_3816scalarNtB5_6Scalar6invert:
  408|   163k|    pub fn invert(&self) -> CtOption<Self> {
  409|       |        #[inline(always)]
  410|       |        fn square_assign_multi(n: &mut Scalar, num_times: usize) {
  411|       |            for _ in 0..num_times {
  412|       |                *n = n.square();
  413|       |            }
  414|       |        }
  415|       |        // found using https://github.com/kwantam/addchain
  416|   163k|        let mut t0 = self.square();
  417|   163k|        let mut t1 = t0 * self;
  418|   163k|        let mut t16 = t0.square();
  419|   163k|        let mut t6 = t16.square();
  420|   163k|        let mut t5 = t6 * t0;
  421|   163k|        t0 = t6 * t16;
  422|   163k|        let mut t12 = t5 * t16;
  423|   163k|        let mut t2 = t6.square();
  424|   163k|        let mut t7 = t5 * t6;
  425|   163k|        let mut t15 = t0 * t5;
  426|   163k|        let mut t17 = t12.square();
  427|   163k|        t1 *= t17;
  428|   163k|        let mut t3 = t7 * t2;
  429|   163k|        let t8 = t1 * t17;
  430|   163k|        let t4 = t8 * t2;
  431|   163k|        let t9 = t8 * t7;
  432|   163k|        t7 = t4 * t5;
  433|   163k|        let t11 = t4 * t17;
  434|   163k|        t5 = t9 * t17;
  435|   163k|        let t14 = t7 * t15;
  436|   163k|        let t13 = t11 * t12;
  437|   163k|        t12 = t11 * t17;
  438|   163k|        t15 *= &t12;
