  640|  15.8M|        let (d1, carry) = adc(self.0[1], rhs.0[1], carry);
  641|  15.8M|        let (d2, carry) = adc(self.0[2], rhs.0[2], carry);
  642|  15.8M|        let (d3, _) = adc(self.0[3], rhs.0[3], carry);
  643|       |
