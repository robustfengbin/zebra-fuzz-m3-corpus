  448|  59.1k|    let Some(halving_div) = halving_divisor(height, net) else {
  449|      4|        return Ok(Amount::zero());
  450|       |    };
  451|       |
  452|  59.1k|    let slow_start_interval = net.slow_start_interval();
  453|       |
  454|       |    // The `floor` fn used in the spec is implicit in Rust's division of primitive integer types.
  455|       |
  456|  59.1k|    let amount = if height < slow_start_interval {
  457|  14.4k|        let slow_start_rate = MAX_BLOCK_SUBSIDY / u64::from(slow_start_interval);
  458|       |
  459|  14.4k|        if height < net.slow_start_shift() {
  460|  14.4k|            slow_start_rate * u64::from(height)
  461|       |        } else {
  462|      0|            slow_start_rate * (u64::from(height) + 1)
  463|       |        }
  464|       |    } else {
  465|  44.6k|        let base_subsidy = if NetworkUpgrade::current(net, height) < NetworkUpgrade::Blossom {
  466|  12.5k|            MAX_BLOCK_SUBSIDY
  467|       |        } else {
  468|  32.1k|            MAX_BLOCK_SUBSIDY / u64::from(BLOSSOM_POW_TARGET_SPACING_RATIO)
  469|       |        };
  470|       |
  471|  44.6k|        base_subsidy / halving_div
  472|       |    };
  473|       |
  474|  59.1k|    Ok(Amount::try_from(amount)?)
  475|  59.1k|}
