  662|  1.33M|        let mask = (((self.0[0] | self.0[1] | self.0[2] | self.0[3]) == 0) as u64).wrapping_sub(1);
  663|       |
  664|  1.33M|        Fr([d0 & mask, d1 & mask, d2 & mask, d3 & mask])
  665|  1.33M|    }
