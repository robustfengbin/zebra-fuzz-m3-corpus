  310|  33.5M|    pub const fn square(&self) -> Fp {
  311|  33.5M|        let (r1, carry) = mac(0, self.0[0], self.0[1], 0);
  312|  33.5M|        let (r2, carry) = mac(0, self.0[0], self.0[2], carry);
  313|  33.5M|        let (r3, r4) = mac(0, self.0[0], self.0[3], carry);
  314|       |
  315|  33.5M|        let (r3, carry) = mac(r3, self.0[1], self.0[2], 0);
  316|  33.5M|        let (r4, r5) = mac(r4, self.0[1], self.0[3], carry);
  317|       |
  318|  33.5M|        let (r5, r6) = mac(r5, self.0[2], self.0[3], 0);
  319|       |
  320|  33.5M|        let r7 = r6 >> 63;
  321|  33.5M|        let r6 = (r6 << 1) | (r5 >> 63);
  322|  33.5M|        let r5 = (r5 << 1) | (r4 >> 63);
  323|  33.5M|        let r4 = (r4 << 1) | (r3 >> 63);
  324|  33.5M|        let r3 = (r3 << 1) | (r2 >> 63);
  325|  33.5M|        let r2 = (r2 << 1) | (r1 >> 63);
  326|  33.5M|        let r1 = r1 << 1;
  327|       |
  328|  33.5M|        let (r0, carry) = mac(0, self.0[0], self.0[0], 0);
  329|  33.5M|        let (r1, carry) = adc(0, r1, carry);
  330|  33.5M|        let (r2, carry) = mac(r2, self.0[1], self.0[1], carry);
  331|  33.5M|        let (r3, carry) = adc(0, r3, carry);
  332|  33.5M|        let (r4, carry) = mac(r4, self.0[2], self.0[2], carry);
  333|  33.5M|        let (r5, carry) = adc(0, r5, carry);
  334|  33.5M|        let (r6, carry) = mac(r6, self.0[3], self.0[3], carry);
  335|  33.5M|        let (r7, _) = adc(0, r7, carry);
  336|       |
  337|  33.5M|        Fp::montgomery_reduce(r0, r1, r2, r3, r4, r5, r6, r7)
