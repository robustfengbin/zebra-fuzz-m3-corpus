  887|  1.58M|    fn add(self, other: &'b ExtendedNielsPoint) -> ExtendedPoint {
  888|       |        // We perform addition in the extended coordinates. Here we use
  889|       |        // a formula presented by Hisil, Wong, Carter and Dawson in
  890|       |        // "Twisted Edward Curves Revisited" which only requires 8M.
  891|       |        //
  892|       |        // A = (V1 - U1) * (V2 - U2)
  893|       |        // B = (V1 + U1) * (V2 + U2)
  894|       |        // C = 2d * T1 * T2
  895|       |        // D = 2 * Z1 * Z2
  896|       |        // E = B - A
  897|       |        // F = D - C
  898|       |        // G = D + C
  899|       |        // H = B + A
  900|       |        // U3 = E * F
  901|       |        // Y3 = G * H
  902|       |        // Z3 = F * G
  903|       |        // T3 = E * H
  904|       |
  905|  1.58M|        let a = (self.v - self.u) * other.v_minus_u;
  906|  1.58M|        let b = (self.v + self.u) * other.v_plus_u;
  907|  1.58M|        let c = self.t1 * self.t2 * other.t2d;
  908|  1.58M|        let d = (self.z * other.z).double();
  909|       |
  910|       |        // The remaining arithmetic is exactly the process of converting
  911|       |        // from a completed point to an extended point.
  912|  1.58M|        CompletedPoint {
  913|  1.58M|            u: b - a,
  914|  1.58M|            v: b + a,
  915|  1.58M|            z: d + c,
  916|  1.58M|            t: d - c,
  917|  1.58M|        }
  918|  1.58M|        .into_extended()
  919|  1.58M|    }
