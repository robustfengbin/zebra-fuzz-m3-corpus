   96|  9.08k|    let div_x = (z2 * x + iso[4] * z4) * x + iso[5] * z6;
   97|       |
   98|  9.08k|    let num_y = (((iso[6] * x + iso[7] * z2) * x + iso[8] * z4) * x + iso[9] * z6) * y;
