  204|    356|            vpub_new: (&mut reader).zcash_deserialize_into()?,
  205|       |            // Type is `B^{ℓ^{Sprout}_{Merkle}}` i.e. 32 bytes.
  206|    356|            anchor: tree::Root::from(reader.read_32_bytes()?),
  207|       |            // Types are `B^{ℓ^{Sprout}_{PRF}}` i.e. 32 bytes.
  208|       |            nullifiers: [
  209|    356|                reader.read_32_bytes()?.into(),
  210|    356|                reader.read_32_bytes()?.into(),
