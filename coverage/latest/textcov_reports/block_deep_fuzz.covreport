  352|       |        // The Montgomery reduction here is based on Algorithm 14.32 in
  353|       |        // Handbook of Applied Cryptography
  354|       |        // <http://cacr.uwaterloo.ca/hac/about/chap14.pdf>.
  355|       |
  356|  61.1M|        let k = r0.wrapping_mul(INV);
  357|  61.1M|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  358|  61.1M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  359|  61.1M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  360|  61.1M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  361|  61.1M|        let (r4, carry2) = adc(r4, 0, carry);
  362|       |
  363|  61.1M|        let k = r1.wrapping_mul(INV);
  364|  61.1M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  365|  61.1M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  366|  61.1M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  367|  61.1M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  368|  61.1M|        let (r5, carry2) = adc(r5, carry2, carry);
  369|       |
  370|  61.1M|        let k = r2.wrapping_mul(INV);
  371|  61.1M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  372|  61.1M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  373|  61.1M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  374|  61.1M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  375|  61.1M|        let (r6, carry2) = adc(r6, carry2, carry);
  376|       |
  377|  61.1M|        let k = r3.wrapping_mul(INV);
  378|  61.1M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  379|  61.1M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  380|  61.1M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  381|  61.1M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  382|  61.1M|        let (r7, _) = adc(r7, carry2, carry);
