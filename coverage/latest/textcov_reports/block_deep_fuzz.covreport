  620|  46.3k|    pub const fn sub(&self, rhs: &Self) -> Self {
  621|  46.3k|        let (d0, borrow) = sbb(self.0[0], rhs.0[0], 0);
  622|  46.3k|        let (d1, borrow) = sbb(self.0[1], rhs.0[1], borrow);
  623|  46.3k|        let (d2, borrow) = sbb(self.0[2], rhs.0[2], borrow);
  624|  46.3k|        let (d3, borrow) = sbb(self.0[3], rhs.0[3], borrow);
  625|       |
  626|       |        // If underflow occurred on the final limb, borrow = 0xfff...fff, otherwise
  627|       |        // borrow = 0x000...000. Thus, we use it as a mask to conditionally add the modulus.
  628|  46.3k|        let (d0, carry) = adc(d0, MODULUS.0[0] & borrow, 0);
  629|  46.3k|        let (d1, carry) = adc(d1, MODULUS.0[1] & borrow, carry);
  630|  46.3k|        let (d2, carry) = adc(d2, MODULUS.0[2] & borrow, carry);
  631|  46.3k|        let (d3, _) = adc(d3, MODULUS.0[3] & borrow, carry);
  632|       |
  633|  46.3k|        Fr([d0, d1, d2, d3])
  634|  46.3k|    }
