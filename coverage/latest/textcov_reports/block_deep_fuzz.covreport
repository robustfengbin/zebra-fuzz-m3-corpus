  345|  78.6k|    if expected_block_subsidy.is_zero() {
  346|  8.17k|        return Ok(results);
  347|  70.5k|    }
  348|       |
  349|  70.5k|    if NetworkUpgrade::current(network, height) >= NetworkUpgrade::Canopy {
  350|  39.0k|        let funding_streams = network.funding_streams(height);
  351|  39.0k|        if let Some(funding_streams) = funding_streams {
  352|  92.6k|            for (&receiver, recipient) in funding_streams.recipients() {
  353|       |                // - Spec equation: `fs.value = floor(block_subsidy(height)*(fs.numerator/fs.denominator))`:
  354|       |                //   https://zips.z.cash/protocol/protocol.pdf#subsidies
  355|       |                // - In Rust, "integer division rounds towards zero":
  356|       |                //   https://doc.rust-lang.org/stable/reference/expressions/operator-expr.html#arithmetic-and-logical-binary-operators
  357|       |                //   This is the same as `floor()`, because these numbers are all positive.
  358|  92.6k|                let amount_value = ((expected_block_subsidy * recipient.numerator())?
  359|      0|                    / FUNDING_STREAM_RECEIVER_DENOMINATOR)?;
  360|       |
  361|  92.6k|                results.insert(receiver, amount_value);
  362|       |            }
  363|    180|        }
  364|  31.4k|    }
  365|       |
  366|  70.5k|    Ok(results)
  367|  78.6k|}
