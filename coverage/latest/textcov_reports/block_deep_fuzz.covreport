  629|  15.8M|        let (d1, carry) = adc(d1, MODULUS.0[1] & borrow, carry);
  630|  15.8M|        let (d2, carry) = adc(d2, MODULUS.0[2] & borrow, carry);
  631|  15.8M|        let (d3, _) = adc(d3, MODULUS.0[3] & borrow, carry);
  632|       |
  633|  15.8M|        Fr([d0, d1, d2, d3])
  634|  15.8M|    }
