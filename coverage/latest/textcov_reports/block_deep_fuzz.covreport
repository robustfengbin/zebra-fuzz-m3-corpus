  127|  18.1k|    pub fn sqrt_ratio(&self, num: &F, div: &F) -> (Choice, F) {
  128|       |        // Based on:
  129|       |        // * [Sarkar2020](https://eprint.iacr.org/2020/1407)
  130|       |        // * [BDLSY2012](https://cr.yp.to/papers.html#ed25519)
  131|       |        //
  132|       |        // We need to calculate uv and v, where v = u^((T-1)/2), u = num/div, and p-1 = T * 2^S.
  133|       |        // We can rewrite as follows:
  134|       |        //
  135|       |        //      v = (num/div)^((T-1)/2)
  136|       |        //        = num^((T-1)/2) * div^(p-1 - (T-1)/2)    [Fermat's Little Theorem]
  137|       |        //        =       "       * div^(T * 2^S - (T-1)/2)
  138|       |        //        =       "       * div^((2^(S+1) - 1)*(T-1)/2 + 2^S)
  139|       |        //        = (num * div^(2^(S+1) - 1))^((T-1)/2) * div^(2^S)
  140|       |        //
  141|       |        // Let  w = (num * div^(2^(S+1) - 1))^((T-1)/2) * div^(2^S - 1).
  142|       |        // Then v = w * div, and uv = num * v / div = num * w.
  143|       |        //
  144|       |        // We calculate:
  145|       |        //
  146|       |        //      s = div^(2^S - 1) using an addition chain
  147|       |        //      t = div^(2^(S+1) - 1) = s^2 * div
  148|       |        //      w = (num * t)^((T-1)/2) * s using another addition chain
  149|       |        //
  150|       |        // then u and uv as above. The addition chains are given in
  151|       |        // https://github.com/zcash/pasta/blob/master/addchain_sqrt.py .
  152|       |        // The overall cost of this part is similar to a single full-width exponentiation,
  153|       |        // regardless of S.
  154|       |
  155|  18.1k|        let sqr = |x: F, i: u32| (0..i).fold(x, |x, _| x.square());
  156|       |
  157|       |        // s = div^(2^S - 1)
  158|  18.1k|        let s = (0..5).fold(*div, |d: F, i| sqr(d, 1 << i) * d);
  159|       |
  160|       |        // t == div^(2^(S+1) - 1)
  161|  18.1k|        let t = s.square() * div;
  162|       |
  163|       |        // w = (num * t)^((T-1)/2) * s
  164|  18.1k|        let w = (t * num).pow_by_t_minus1_over2() * s;
  165|       |
  166|       |        // v == u^((T-1)/2)
  167|  18.1k|        let v = w * div;
  168|       |
  169|       |        // uv = u * v
  170|  18.1k|        let uv = w * num;
  171|       |
  172|  18.1k|        let res = self.sqrt_common(&uv, &v);
  173|       |
  174|  18.1k|        let sqdiv = res.square() * div;
  175|  18.1k|        let is_square = (sqdiv - num).is_zero();
  176|  18.1k|        let is_nonsquare = (sqdiv - F::ROOT_OF_UNITY * num).is_zero();
  177|  18.1k|        assert!(bool::from(
  178|  18.1k|            num.is_zero() | div.is_zero() | (is_square ^ is_nonsquare)
  179|  18.1k|        ));
  180|       |
  181|  18.1k|        (is_square, res)
  182|  18.1k|    }
