_RNvMsa_NtCsjpkeS12E7YP_9bls12_3816scalarNtB5_6Scalar17montgomery_reduce:
  506|   124M|    const fn montgomery_reduce(
  507|   124M|        r0: u64,
  508|   124M|        r1: u64,
  509|   124M|        r2: u64,
  510|   124M|        r3: u64,
  511|   124M|        r4: u64,
  512|   124M|        r5: u64,
  513|   124M|        r6: u64,
  514|   124M|        r7: u64,
  515|   124M|    ) -> Self {
  516|       |        // The Montgomery reduction here is based on Algorithm 14.32 in
  517|       |        // Handbook of Applied Cryptography
  518|       |        // <http://cacr.uwaterloo.ca/hac/about/chap14.pdf>.
  519|       |
  520|   124M|        let k = r0.wrapping_mul(INV);
  521|   124M|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  522|   124M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  523|   124M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  524|   124M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  525|   124M|        let (r4, carry2) = adc(r4, 0, carry);
  526|       |
  527|   124M|        let k = r1.wrapping_mul(INV);
  528|   124M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  529|   124M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  530|   124M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  531|   124M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  532|   124M|        let (r5, carry2) = adc(r5, carry2, carry);
  533|       |
  534|   124M|        let k = r2.wrapping_mul(INV);
  535|   124M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  536|   124M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  537|   124M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  538|   124M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  539|   124M|        let (r6, carry2) = adc(r6, carry2, carry);
  540|       |
  541|   124M|        let k = r3.wrapping_mul(INV);
  542|   124M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  543|   124M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  544|   124M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  545|   124M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  546|   124M|        let (r7, _) = adc(r7, carry2, carry);
  547|       |
  548|       |        // Result may be within MODULUS of the correct value
  549|   124M|        (&Scalar([r4, r5, r6, r7])).sub(&MODULUS)
  550|   124M|    }
