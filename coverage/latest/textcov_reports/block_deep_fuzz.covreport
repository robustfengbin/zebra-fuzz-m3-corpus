  296|  46.3k|    pub fn to_bytes(&self) -> [u8; 32] {
  297|       |        // Turn into canonical form by computing
  298|       |        // (a.R) / R = a
  299|  46.3k|        let tmp = Fr::montgomery_reduce(self.0[0], self.0[1], self.0[2], self.0[3], 0, 0, 0, 0);
  300|       |
  301|  46.3k|        let mut res = [0; 32];
  302|  46.3k|        res[0..8].copy_from_slice(&tmp.0[0].to_le_bytes());
  303|  46.3k|        res[8..16].copy_from_slice(&tmp.0[1].to_le_bytes());
  304|  46.3k|        res[16..24].copy_from_slice(&tmp.0[2].to_le_bytes());
  305|  46.3k|        res[24..32].copy_from_slice(&tmp.0[3].to_le_bytes());
  306|       |
  307|  46.3k|        res
  308|  46.3k|    }
