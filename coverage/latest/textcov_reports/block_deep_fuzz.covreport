  554|  16.3M|    pub const fn mul(&self, rhs: &Self) -> Self {
  555|       |        // Schoolbook multiplication
  556|       |
  557|  16.3M|        let (r0, carry) = mac(0, self.0[0], rhs.0[0], 0);
  558|  16.3M|        let (r1, carry) = mac(0, self.0[0], rhs.0[1], carry);
  559|  16.3M|        let (r2, carry) = mac(0, self.0[0], rhs.0[2], carry);
  560|  16.3M|        let (r3, r4) = mac(0, self.0[0], rhs.0[3], carry);
  561|       |
  562|  16.3M|        let (r1, carry) = mac(r1, self.0[1], rhs.0[0], 0);
  563|  16.3M|        let (r2, carry) = mac(r2, self.0[1], rhs.0[1], carry);
  564|  16.3M|        let (r3, carry) = mac(r3, self.0[1], rhs.0[2], carry);
  565|  16.3M|        let (r4, r5) = mac(r4, self.0[1], rhs.0[3], carry);
  566|       |
  567|  16.3M|        let (r2, carry) = mac(r2, self.0[2], rhs.0[0], 0);
  568|  16.3M|        let (r3, carry) = mac(r3, self.0[2], rhs.0[1], carry);
  569|  16.3M|        let (r4, carry) = mac(r4, self.0[2], rhs.0[2], carry);
  570|  16.3M|        let (r5, r6) = mac(r5, self.0[2], rhs.0[3], carry);
  571|       |
  572|  16.3M|        let (r3, carry) = mac(r3, self.0[3], rhs.0[0], 0);
  573|  16.3M|        let (r4, carry) = mac(r4, self.0[3], rhs.0[1], carry);
  574|  16.3M|        let (r5, carry) = mac(r5, self.0[3], rhs.0[2], carry);
  575|  16.3M|        let (r6, r7) = mac(r6, self.0[3], rhs.0[3], carry);
  576|       |
  577|  16.3M|        Scalar::montgomery_reduce(r0, r1, r2, r3, r4, r5, r6, r7)
  578|  16.3M|    }
_RNvMsa_NtCsjpkeS12E7YP_9bls12_3816scalarNtB5_6Scalar3negCs3VjbIwwZMBL_6jubjub:
  613|  58.1k|    pub const fn neg(&self) -> Self {
  614|       |        // Subtract `self` from `MODULUS` to negate. Ignore the final
  615|       |        // borrow because it cannot underflow; self is guaranteed to
  616|       |        // be in the field.
  617|  58.1k|        let (d0, borrow) = sbb(MODULUS.0[0], self.0[0], 0);
  618|  58.1k|        let (d1, borrow) = sbb(MODULUS.0[1], self.0[1], borrow);
  619|  58.1k|        let (d2, borrow) = sbb(MODULUS.0[2], self.0[2], borrow);
  620|  58.1k|        let (d3, _) = sbb(MODULUS.0[3], self.0[3], borrow);
  621|       |
  622|       |        // `tmp` could be `MODULUS` if `self` was zero. Create a mask that is
  623|       |        // zero if `self` was zero, and `u64::max_value()` if self was nonzero.
  624|  58.1k|        let mask = (((self.0[0] | self.0[1] | self.0[2] | self.0[3]) == 0) as u64).wrapping_sub(1);
  625|       |
  626|  58.1k|        Scalar([d0 & mask, d1 & mask, d2 & mask, d3 & mask])
  627|  58.1k|    }
