  418|  98.4k|pub fn halving(height: Height, network: &Network) -> u32 {
  419|  98.4k|    let slow_start_shift = network.slow_start_shift();
  420|  98.4k|    let blossom_height = NetworkUpgrade::Blossom
  421|  98.4k|        .activation_height(network)
  422|  98.4k|        .expect("blossom activation height should be available");
  423|       |
  424|  98.4k|    let halving_index = if height < slow_start_shift {
  425|  21.7k|        0
  426|  76.7k|    } else if height < blossom_height {
  427|  18.8k|        let pre_blossom_height = height - slow_start_shift;
  428|  18.8k|        pre_blossom_height / network.pre_blossom_halving_interval()
  429|       |    } else {
  430|  57.9k|        let pre_blossom_height = blossom_height - slow_start_shift;
  431|  57.9k|        let scaled_pre_blossom_height =
  432|  57.9k|            pre_blossom_height * HeightDiff::from(BLOSSOM_POW_TARGET_SPACING_RATIO);
  433|       |
  434|  57.9k|        let post_blossom_height = height - blossom_height;
  435|       |
  436|  57.9k|        (scaled_pre_blossom_height + post_blossom_height) / network.post_blossom_halving_interval()
  437|       |    };
  438|       |
  439|  98.4k|    halving_index
  440|  98.4k|        .try_into()
  441|  98.4k|        .expect("already checked for negatives")
  442|  98.4k|}
