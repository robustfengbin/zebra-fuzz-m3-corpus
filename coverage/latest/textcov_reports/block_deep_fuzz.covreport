  102|  9.08k|    let xo = num_x * div_y * zo;
  103|  9.08k|    let yo = num_y * div_x * zo.square();
  104|       |
  105|  9.08k|    C::new_jacobian(xo, yo, zo).unwrap()
  106|  9.08k|}

