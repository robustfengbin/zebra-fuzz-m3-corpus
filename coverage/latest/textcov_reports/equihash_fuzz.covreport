_RNvNtCsgZX4mSu3YR4_12blake2b_simd4avx214compress1_loop:
  437|   104k|pub unsafe fn compress1_loop(
  438|   104k|    input: &[u8],
  439|   104k|    words: &mut [Word; 8],
  440|   104k|    mut count: Count,
  441|   104k|    last_node: LastNode,
  442|   104k|    finalize: Finalize,
  443|   104k|    stride: Stride,
  444|   104k|) {
  445|       |    unsafe {
  446|   104k|        input_debug_asserts(input, finalize);
  447|       |
  448|   104k|        let mut local_words = *words;
  449|       |
  450|   104k|        let mut fin_offset = input.len().saturating_sub(1);
  451|   104k|        fin_offset -= fin_offset % stride.padded_blockbytes();
  452|   104k|        let mut buf = [0; BLOCKBYTES];
  453|   104k|        let (fin_block, fin_len, _) = final_block(input, fin_offset, &mut buf, stride);
  454|   104k|        let fin_last_block = flag_word(finalize.yes());
  455|   104k|        let fin_last_node = flag_word(finalize.yes() && last_node.yes());
  456|       |
  457|   104k|        let mut offset = 0;
  458|       |        loop {
  459|       |            let block;
  460|       |            let count_delta;
  461|       |            let last_block;
  462|       |            let last_node;
  463|   104k|            if offset == fin_offset {
  464|   104k|                block = fin_block;
  465|   104k|                count_delta = fin_len;
  466|   104k|                last_block = fin_last_block;
  467|   104k|                last_node = fin_last_node;
  468|   104k|            } else {
  469|      0|                // This unsafe cast avoids bounds checks. There's guaranteed to be
  470|      0|                // enough input because `offset < fin_offset`.
  471|      0|                block = &*(input.as_ptr().add(offset) as *const [u8; BLOCKBYTES]);
  472|      0|                count_delta = BLOCKBYTES;
  473|      0|                last_block = flag_word(false);
  474|      0|                last_node = flag_word(false);
  475|      0|            };
  476|       |
  477|   104k|            count = count.wrapping_add(count_delta as Count);
  478|   104k|            compress_block(block, &mut local_words, count, last_block, last_node);
  479|       |
  480|       |            // Check for termination before bumping the offset, to avoid overflow.
  481|   104k|            if offset == fin_offset {
  482|   104k|                break;
  483|      0|            }
  484|       |
  485|      0|            offset += stride.padded_blockbytes();
  486|       |        }
  487|       |
  488|   104k|        *words = local_words;
  489|       |    }
  490|   104k|}
