  269|      0|                    let mut file = std::fs::File::create(path)
  270|      0|                        .expect("failed to create `RUST_LIBFUZZER_DEBUG_PATH` file");
  271|      0|                    writeln!(&mut file, "{:?}", bytes)
  272|      0|                        .expect("failed to write to `RUST_LIBFUZZER_DEBUG_PATH` file");
  273|      0|                    return 0;
  274|    672|                }
