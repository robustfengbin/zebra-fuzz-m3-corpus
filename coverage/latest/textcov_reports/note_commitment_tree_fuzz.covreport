   11|  57.5k|pub fn hash_to_field<F: FromUniformBytes<64>>(
   12|  57.5k|    curve_id: &str,
   13|  57.5k|    domain_prefix: &str,
   14|  57.5k|    message: &[u8],
   15|  57.5k|    buf: &mut [F; 2],
   16|  57.5k|) {
   17|  57.5k|    assert!(domain_prefix.len() < 256);
   18|  57.5k|    assert!((22 + curve_id.len() + domain_prefix.len()) < 256);
   19|       |
   20|       |    // Assume that the field size is 32 bytes and k is 256, where k is defined in
   21|       |    // <https://www.ietf.org/archive/id/draft-irtf-cfrg-hash-to-curve-10.html#name-security-considerations-3>.
   22|       |    const CHUNKLEN: usize = 64;
   23|       |    const_assert!(CHUNKLEN * 2 < 256);
   24|       |
   25|       |    // Input block size of BLAKE2b.
   26|       |    const R_IN_BYTES: usize = 128;
   27|       |
