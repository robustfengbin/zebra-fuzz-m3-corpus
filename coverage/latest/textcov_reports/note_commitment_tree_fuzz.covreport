  291|  11.9M|            fn ct_eq(&self, other: &Self) -> Choice {
  292|       |                // Is (xz^2, yz^3, z) equal to (x'z'^2, yz'^3, z') when converted to affine?
  293|       |
  294|  11.9M|                let z = other.z.square();
  295|  11.9M|                let x1 = self.x * z;
  296|  11.9M|                let z = z * other.z;
  297|  11.9M|                let y1 = self.y * z;
  298|  11.9M|                let z = self.z.square();
  299|  11.9M|                let x2 = other.x * z;
  300|  11.9M|                let z = z * self.z;
  301|  11.9M|                let y2 = other.y * z;
  302|       |
  303|  11.9M|                let self_is_zero = self.is_identity();
  304|  11.9M|                let other_is_zero = other.is_identity();
  305|       |
  306|  11.9M|                (self_is_zero & other_is_zero) // Both point at infinity
  307|  11.9M|                            | ((!self_is_zero) & (!other_is_zero) & x1.ct_eq(&x2) & y1.ct_eq(&y2))
  308|       |                // Neither point at infinity, coordinates are the same
  309|  11.9M|            }
