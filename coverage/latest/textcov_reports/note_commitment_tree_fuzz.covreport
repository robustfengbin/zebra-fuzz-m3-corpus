  127|   115k|    pub fn sqrt_ratio(&self, num: &F, div: &F) -> (Choice, F) {
  128|       |        // Based on:
  129|       |        // * [Sarkar2020](https://eprint.iacr.org/2020/1407)
  130|       |        // * [BDLSY2012](https://cr.yp.to/papers.html#ed25519)
  131|       |        //
  132|       |        // We need to calculate uv and v, where v = u^((T-1)/2), u = num/div, and p-1 = T * 2^S.
  133|       |        // We can rewrite as follows:
  134|       |        //
  135|       |        //      v = (num/div)^((T-1)/2)
  136|       |        //        = num^((T-1)/2) * div^(p-1 - (T-1)/2)    [Fermat's Little Theorem]
  137|       |        //        =       "       * div^(T * 2^S - (T-1)/2)
  138|       |        //        =       "       * div^((2^(S+1) - 1)*(T-1)/2 + 2^S)
  139|       |        //        = (num * div^(2^(S+1) - 1))^((T-1)/2) * div^(2^S)
  140|       |        //
  141|       |        // Let  w = (num * div^(2^(S+1) - 1))^((T-1)/2) * div^(2^S - 1).
  142|       |        // Then v = w * div, and uv = num * v / div = num * w.
  143|       |        //
  144|       |        // We calculate:
  145|       |        //
  146|       |        //      s = div^(2^S - 1) using an addition chain
  147|       |        //      t = div^(2^(S+1) - 1) = s^2 * div
  148|       |        //      w = (num * t)^((T-1)/2) * s using another addition chain
  149|       |        //
  150|       |        // then u and uv as above. The addition chains are given in
  151|       |        // https://github.com/zcash/pasta/blob/master/addchain_sqrt.py .
  152|       |        // The overall cost of this part is similar to a single full-width exponentiation,
  153|       |        // regardless of S.
  154|       |
  155|   115k|        let sqr = |x: F, i: u32| (0..i).fold(x, |x, _| x.square());
  156|       |
  157|       |        // s = div^(2^S - 1)
  158|   115k|        let s = (0..5).fold(*div, |d: F, i| sqr(d, 1 << i) * d);
  159|       |
  160|       |        // t == div^(2^(S+1) - 1)
  161|   115k|        let t = s.square() * div;
  162|       |
  163|       |        // w = (num * t)^((T-1)/2) * s
  164|   115k|        let w = (t * num).pow_by_t_minus1_over2() * s;
  165|       |
  166|       |        // v == u^((T-1)/2)
  167|   115k|        let v = w * div;
  168|       |
  169|       |        // uv = u * v
  170|   115k|        let uv = w * num;
  171|       |
  172|   115k|        let res = self.sqrt_common(&uv, &v);
  173|       |
  174|   115k|        let sqdiv = res.square() * div;
  175|   115k|        let is_square = (sqdiv - num).is_zero();
  176|   115k|        let is_nonsquare = (sqdiv - F::ROOT_OF_UNITY * num).is_zero();
  177|   115k|        assert!(bool::from(
  178|   115k|            num.is_zero() | div.is_zero() | (is_square ^ is_nonsquare)
  179|   115k|        ));
  180|       |
  181|   115k|        (is_square, res)
  182|   115k|    }
_RNvMs_NtNtCs41Au54XfBWR_12pasta_curves10arithmetic6fieldsINtB4_10SqrtTablesNtNtNtB8_6fields2fp2FpE11sqrt_commonB8_:
  200|   115k|    fn sqrt_common(&self, uv: &F, v: &F) -> F {
  201|   115k|        let sqr = |x: F, i: u32| (0..i).fold(x, |x, _| x.square());
  202|   115k|        let inv = |x: F| self.inv[self.hasher.hash(&x)] as usize;
  203|       |
  204|   115k|        let x3 = *uv * v;
  205|   115k|        let x2 = sqr(x3, 8);
  206|   115k|        let x1 = sqr(x2, 8);
  207|   115k|        let x0 = sqr(x1, 8);
  208|       |
  209|       |        // i = 0, 1
  210|   115k|        let mut t_ = inv(x0); // = t >> 16
  211|       |                              // 1 == x0 * ROOT_OF_UNITY^(t_ << 24)
  212|   115k|        assert!(t_ < 0x100);
  213|   115k|        let alpha = x1 * self.g2[t_];
  214|       |
  215|       |        // i = 2
  216|   115k|        t_ += inv(alpha) << 8; // = t >> 8
  217|       |                               // 1 == x1 * ROOT_OF_UNITY^(t_ << 16)
  218|   115k|        assert!(t_ < 0x10000);
  219|   115k|        let alpha = x2 * self.g1[t_ & 0xFF] * self.g2[t_ >> 8];
  220|       |
  221|       |        // i = 3
  222|   115k|        t_ += inv(alpha) << 16; // = t
  223|       |                                // 1 == x2 * ROOT_OF_UNITY^(t_ << 8)
  224|   115k|        assert!(t_ < 0x1000000);
  225|   115k|        let alpha = x3 * self.g0[t_ & 0xFF] * self.g1[(t_ >> 8) & 0xFF] * self.g2[t_ >> 16];
  226|       |
  227|   115k|        t_ += inv(alpha) << 24; // = t << 1
  228|       |                                // 1 == x3 * ROOT_OF_UNITY^t_
  229|   115k|        t_ = (((t_ as u64) + 1) >> 1) as usize;
  230|   115k|        assert!(t_ <= 0x80000000);
  231|       |
  232|   115k|        *uv * self.g0[t_ & 0xFF]
  233|   115k|            * self.g1[(t_ >> 8) & 0xFF]
  234|   115k|            * self.g2[(t_ >> 16) & 0xFF]
  235|   115k|            * self.g3[t_ >> 24]
  236|   115k|    }
_RNvMs_NtNtCs41Au54XfBWR_12pasta_curves10arithmetic6fieldsINtB4_10SqrtTablesNtNtNtB8_6fields2fp2FpE3newB8_:
   69|      1|    pub fn new(hash_xor: u32, hash_mod: usize) -> Self {
   70|       |        use alloc::vec;
   71|       |
   72|      1|        let hasher = SqrtHasher {
   73|      1|            hash_xor,
   74|      1|            hash_mod,
   75|      1|            marker: PhantomData,
   76|      1|        };
   77|       |
   78|      1|        let mut gtab = (0..4).scan(F::ROOT_OF_UNITY, |gi, _| {
   79|       |            // gi == ROOT_OF_UNITY^(256^i)
   80|       |            let gtab_i: Vec<F> = (0..256)
   81|       |                .scan(F::ONE, |acc, _| {
   82|       |                    let res = *acc;
   83|       |                    *acc *= *gi;
   84|       |                    Some(res)
   85|       |                })
   86|       |                .collect();
   87|       |            *gi = gtab_i[255] * *gi;
   88|       |            Some(gtab_i)
   89|       |        });
   90|      1|        let gtab_0 = gtab.next().unwrap();
   91|      1|        let gtab_1 = gtab.next().unwrap();
   92|      1|        let gtab_2 = gtab.next().unwrap();
   93|      1|        let mut gtab_3 = gtab.next().unwrap();
   94|      1|        assert_eq!(gtab.next(), None);
   95|       |
   96|       |        // Now invert gtab[3].
   97|      1|        let mut inv: Vec<u8> = vec![1; hash_mod];
   98|    256|        for (j, gtab_3_j) in gtab_3.iter().enumerate() {
   99|    256|            let hash = hasher.hash(gtab_3_j);
  100|       |            // 1 is the last value to be assigned, so this ensures there are no collisions.
  101|    256|            assert!(inv[hash] == 1);
  102|    256|            inv[hash] = ((256 - j) & 0xFF) as u8;
  103|       |        }
  104|       |
  105|      1|        gtab_3.truncate(129);
  106|       |
  107|      1|        SqrtTables::<F> {
  108|      1|            hasher,
  109|      1|            inv,
  110|      1|            g0: gtab_0.into_boxed_slice().try_into().unwrap(),
  111|      1|            g1: gtab_1.into_boxed_slice().try_into().unwrap(),
  112|      1|            g2: gtab_2.into_boxed_slice().try_into().unwrap(),
  113|      1|            g3: gtab_3.into_boxed_slice().try_into().unwrap(),
  114|      1|        }
  115|      1|    }

