   35|  57.5k|        .clone()
   36|  57.5k|        .update(&[0; R_IN_BYTES])
   37|  57.5k|        .update(message)
   38|  57.5k|        .update(&[0, (CHUNKLEN * 2) as u8, 0])
   39|  57.5k|        .update(domain_prefix.as_bytes())
   40|  57.5k|        .update(b"-")
   41|  57.5k|        .update(curve_id.as_bytes())
   42|  57.5k|        .update(b"_XMD:BLAKE2b_SSWU_RO_")
   43|  57.5k|        .update(&[(22 + curve_id.len() + domain_prefix.len()) as u8])
   44|  57.5k|        .finalize();
   45|       |
   46|  57.5k|    let b_1 = empty_hasher
   47|  57.5k|        .clone()
   48|  57.5k|        .update(b_0.as_array())
   49|  57.5k|        .update(&[1])
   50|  57.5k|        .update(domain_prefix.as_bytes())
   51|  57.5k|        .update(b"-")
   52|  57.5k|        .update(curve_id.as_bytes())
   53|  57.5k|        .update(b"_XMD:BLAKE2b_SSWU_RO_")
   54|  57.5k|        .update(&[(22 + curve_id.len() + domain_prefix.len()) as u8])
