  436|      1|    pub const fn add(&self, rhs: &Self) -> Self {
  437|      1|        let (d0, carry) = adc(self.0[0], rhs.0[0], 0);
  438|      1|        let (d1, carry) = adc(self.0[1], rhs.0[1], carry);
  439|      1|        let (d2, carry) = adc(self.0[2], rhs.0[2], carry);
  440|      1|        let (d3, _) = adc(self.0[3], rhs.0[3], carry);
  441|       |
  442|       |        // Attempt to subtract the modulus, to ensure the value
  443|       |        // is smaller than the modulus.
  444|      1|        (&Fp([d0, d1, d2, d3])).sub(&MODULUS)
  445|      1|    }
