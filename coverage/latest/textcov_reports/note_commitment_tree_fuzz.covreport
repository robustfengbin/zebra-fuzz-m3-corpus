  521|  78.2M|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  522|  78.2M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  523|  78.2M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  524|  78.2M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  525|  78.2M|        let (r4, carry2) = adc(r4, 0, carry);
  526|       |
  527|  78.2M|        let k = r1.wrapping_mul(INV);
  528|  78.2M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  529|  78.2M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  530|  78.2M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  531|  78.2M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  532|  78.2M|        let (r5, carry2) = adc(r5, carry2, carry);
  533|       |
  534|  78.2M|        let k = r2.wrapping_mul(INV);
  535|  78.2M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  536|  78.2M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  537|  78.2M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  538|  78.2M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  539|  78.2M|        let (r6, carry2) = adc(r6, carry2, carry);
  540|       |
  541|  78.2M|        let k = r3.wrapping_mul(INV);
  542|  78.2M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  543|  78.2M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  544|  78.2M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  545|  78.2M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
