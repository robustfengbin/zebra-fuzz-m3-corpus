  157|   115k|            fn is_on_curve(&self) -> Choice {
  158|       |                // Y^2 = X^3 + AX(Z^4) + b(Z^6)
  159|       |                // Y^2 - (X^2 + A(Z^4))X = b(Z^6)
  160|       |
  161|   115k|                let z2 = self.z.square();
  162|   115k|                let z4 = z2.square();
  163|   115k|                let z6 = z4 * z2;
  164|   115k|                (self.y.square() - (self.x.square() + $name::curve_constant_a() * z4) * self.x)
