  246|      1|fn generate_pedersen_hash_exp_table() -> Vec<Vec<Vec<SubgroupPoint>>> {
  247|      1|    let window = PEDERSEN_HASH_EXP_WINDOW_SIZE;
  248|       |
  249|      1|    PEDERSEN_HASH_GENERATORS
  250|      1|        .iter()
  251|      1|        .cloned()
  252|      1|        .map(|mut g| {
  253|       |            let mut tables = vec![];
  254|       |
  255|       |            let mut num_bits = 0;
  256|       |            while num_bits <= jubjub::Fr::NUM_BITS {
  257|       |                let mut table = Vec::with_capacity(1 << window);
  258|       |                let mut base = SubgroupPoint::identity();
  259|       |
  260|       |                for _ in 0..(1 << window) {
  261|       |                    table.push(base);
  262|       |                    base += g;
  263|       |                }
  264|       |
  265|       |                tables.push(table);
  266|       |                num_bits += window;
  267|       |
  268|       |                for _ in 0..window {
  269|       |                    g = g.double();
  270|       |                }
  271|       |            }
  272|       |
  273|       |            tables
