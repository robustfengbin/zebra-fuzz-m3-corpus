   58|  57.5k|        let mut empty_hasher = empty_hasher;
   59|  3.68M|        for (l, r) in b_0.as_array().iter().zip(b_1.as_array().iter()) {
   60|  3.68M|            empty_hasher.update(&[*l ^ *r]);
   61|  3.68M|        }
   62|  57.5k|        empty_hasher
   63|  57.5k|            .update(&[2])
   64|  57.5k|            .update(domain_prefix.as_bytes())
   65|  57.5k|            .update(b"-")
   66|  57.5k|            .update(curve_id.as_bytes())
   67|  57.5k|            .update(b"_XMD:BLAKE2b_SSWU_RO_")
   68|  57.5k|            .update(&[(22 + curve_id.len() + domain_prefix.len()) as u8])
   69|  57.5k|            .finalize()
   70|       |    };
   71|       |
   72|   115k|    for (big, buf) in [b_1, b_2].iter().zip(buf.iter_mut()) {
   73|   115k|        let mut little = [0u8; CHUNKLEN];
