  100|       |
  101|  57.5k|    let zo = div_x * div_y;
  102|  57.5k|    let xo = num_x * div_y * zo;
  103|  57.5k|    let yo = num_y * div_x * zo.square();
  104|       |
  105|  57.5k|    C::new_jacobian(xo, yo, zo).unwrap()
  106|  57.5k|}

