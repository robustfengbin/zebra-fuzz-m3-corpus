  508|  78.2M|        r1: u64,
  509|  78.2M|        r2: u64,
  510|  78.2M|        r3: u64,
  511|  78.2M|        r4: u64,
  512|  78.2M|        r5: u64,
  513|  78.2M|        r6: u64,
