  229|  2.32k|fn hash_header_txid_data(
  230|  2.32k|    version: TxVersion,
  231|  2.32k|    // we commit to the consensus branch ID with the header
  232|  2.32k|    consensus_branch_id: BranchId,
  233|  2.32k|    lock_time: u32,
  234|  2.32k|    expiry_height: BlockHeight,
