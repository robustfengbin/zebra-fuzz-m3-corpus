_RNvNtNtCs8jXVBPYSQuE_6chrono5naive4date11cycle_to_yo:
 2422|    419|const fn cycle_to_yo(cycle: u32) -> (u32, u32) {
 2423|    419|    let mut year_mod_400 = cycle / 365;
 2424|    419|    let mut ordinal0 = cycle % 365;
