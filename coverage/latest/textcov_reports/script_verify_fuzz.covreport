  240|  2.32k|    h.write_u32_le(version.version_group_id()).unwrap();
  241|  2.32k|    h.write_u32_le(consensus_branch_id.into()).unwrap();
  242|  2.32k|    h.write_u32_le(lock_time).unwrap();
  243|  2.32k|    h.write_u32_le(expiry_height.into()).unwrap();
