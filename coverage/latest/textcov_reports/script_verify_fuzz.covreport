  143|     43|    fn zcash_serialize<W: io::Write>(&self, mut writer: W) -> Result<(), io::Error> {
  144|     43|        self.vpub_old.zcash_serialize(&mut writer)?;
  145|     43|        self.vpub_new.zcash_serialize(&mut writer)?;
  146|       |
  147|     43|        writer.write_32_bytes(&self.anchor.into())?;
  148|     43|        writer.write_32_bytes(&self.nullifiers[0].into())?;
  149|     43|        writer.write_32_bytes(&self.nullifiers[1].into())?;
  150|     43|        writer.write_32_bytes(&self.commitments[0].into())?;
  151|     43|        writer.write_32_bytes(&self.commitments[1].into())?;
  152|       |
  153|     43|        writer.write_all(&self.ephemeral_key.as_bytes()[..])?;
  154|       |        // The borrow is actually needed to avoid taking ownership
  155|       |        #[allow(clippy::needless_borrow)]
