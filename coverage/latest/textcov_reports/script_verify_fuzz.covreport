_RNvCsksliLkfRIs8_18script_verify_fuzz14drive_is_valid:
  272|  2.32k|fn drive_is_valid(
  273|  2.32k|    tx: &Arc<Transaction>,
  274|  2.32k|    prev_outputs: Arc<Vec<transparent::Output>>,
  275|  2.32k|    nu: NetworkUpgrade,
  276|  2.32k|    idx_sel: u8,
  277|  2.32k|    inputs_len: usize,
  278|  2.32k|) {
  279|       |    // ───────────────────────────────────────────────────────────────────
  280|       |    // Invariant S-1: CachedFfiTransaction::new must not Rust-panic.
  281|       |    //
  282|       |    // Constructor failure (returns Err) is the expected graceful path
  283|       |    // for inconsistent (version, NU) pairs or malformed bundles — that
  284|       |    // is **not** a fuzz signal. A panic here would indicate a missed
  285|       |    // error-handling case in `transaction.sighasher`.
  286|       |    // ───────────────────────────────────────────────────────────────────
  287|  2.32k|    let cached = match panic::catch_unwind(panic::AssertUnwindSafe(|| {
  288|       |        CachedFfiTransaction::new(tx.clone(), prev_outputs, nu)
  289|       |    })) {
  290|  2.32k|        Ok(Ok(c)) => c,
  291|       |        // Constructor returned Err — graceful failure, skip.
  292|      0|        Ok(Err(_)) => return,
  293|       |        // Constructor panicked — libfuzzer already records the crash.
  294|      0|        Err(_) => return,
  295|       |    };
  296|       |
  297|       |    // Pick the input index modulo the number of inputs. We also test
  298|       |    // an out-of-bounds index to exercise the `Error::TxIndex` path,
  299|       |    // because the bounds check is the last Rust gate before the FFI
  300|       |    // dereference and a future refactor could regress it.
  301|  2.32k|    let in_bounds = (idx_sel as usize) % inputs_len;
  302|  2.32k|    let oob = inputs_len; // exactly one past the end
  303|       |
  304|       |    // ───────────────────────────────────────────────────────────────────
  305|       |    // Invariant S-2: is_valid(in_bounds) must not Rust-panic.
  306|       |    //
  307|       |    // This is the **primary** FFI surface. Inside `is_valid`:
  308|       |    //   - We read the lock_script from the mock prev_output.
  309|       |    //   - We construct `zcash_script::interpreter::Flags::P2SH |
  310|       |    //     CHECKLOCKTIMEVERIFY`.
  311|       |    //   - We unwrap the input's `unlock_script` (rejects Coinbase ⇒
  312|       |    //     returns Error::TxCoinbase, so coinbase txs are pre-filtered
  313|       |    //     above).
  314|       |    //   - We invoke `interpreter.verify_callback(&script, flags)` which
  315|       |    //     trampolines through libzcash_script into the C interpreter.
  316|       |    //
  317|       |    // SIGSEGV / SIGFPE / OOM / unbounded-loop in the C library is the
  318|       |    // highest-severity crash class for this surface. Rust panics on this
  319|       |    // path are also high-value (FFI bridge bugs).
  320|       |    // ───────────────────────────────────────────────────────────────────
  321|  2.32k|    let _ = panic::catch_unwind(panic::AssertUnwindSafe(|| {
  322|       |        let _ = cached.is_valid(in_bounds);
  323|       |    }));
  324|       |
  325|       |    // ───────────────────────────────────────────────────────────────────
  326|       |    // Invariant S-3: is_valid(out_of_bounds) returns Err, never panics.
  327|       |    //
  328|       |    // Defensive: confirms the explicit index check at lib.rs:134
  329|       |    // (`self.all_previous_outputs.get(input_index).ok_or(Error::TxIndex)?`)
  330|       |    // is the only gate. A panic here would mean the OOB check is being
  331|       |    // bypassed somewhere — unlikely today, but cheap to assert.
  332|       |    // ───────────────────────────────────────────────────────────────────
  333|  2.32k|    let _ = panic::catch_unwind(panic::AssertUnwindSafe(|| {
  334|       |        let res = cached.is_valid(oob);
  335|       |        // We only assert the shape (must be Err) when the call returned
  336|       |        // — a Rust panic is caught above and is itself the finding.
  337|       |        debug_assert!(res.is_err(), "S-3 violated: out-of-bounds is_valid returned Ok");
  338|       |    }));
  339|       |
  340|       |    // ───────────────────────────────────────────────────────────────────
  341|       |    // Invariant S-4: Sigops::sigops() must not Rust-panic.
  342|       |    //
  343|       |    // The companion FFI entry point on `CachedFfiTransaction` is
  344|       |    // `Sigops::sigops`, which iterates every input/output script and
  345|       |    // calls `interpreter.legacy_sigop_count_script` for each — another
  346|       |    // FFI trampoline into the C library. Same SIGSEGV / overflow class
  347|       |    // as `is_valid`, different opcode dispatch table on the C side.
  348|       |    // ───────────────────────────────────────────────────────────────────
  349|  2.32k|    let _ = panic::catch_unwind(panic::AssertUnwindSafe(|| {
  350|       |        use zebra_script::Sigops;
  351|       |        let _ = cached.sigops();
  352|       |    }));
  353|  2.32k|}

