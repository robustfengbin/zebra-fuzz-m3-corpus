 1490|    419|    const fn from_yof(yof: i32) -> NaiveDate {
 1491|       |        // The following are the invariants our ordinal and flags should uphold for a valid
 1492|       |        // `NaiveDate`.
 1493|    419|        debug_assert!(((yof & OL_MASK) >> 3) > 1);
 1494|    419|        debug_assert!(((yof & OL_MASK) >> 3) <= MAX_OL);
 1495|    419|        debug_assert!((yof & 0b111) != 000);
