  229|    308|fn hash_header_txid_data(
  230|    308|    version: TxVersion,
  231|    308|    // we commit to the consensus branch ID with the header
  232|    308|    consensus_branch_id: BranchId,
  233|    308|    lock_time: u32,
  234|    308|    expiry_height: BlockHeight,
  235|    308|    #[cfg(all(zcash_unstable = "nu7", feature = "zip-233"))] zip233_amount: &Zatoshis,
  236|    308|) -> Blake2bHash {
  237|    308|    let mut h = hasher(ZCASH_HEADERS_HASH_PERSONALIZATION);
  238|       |
  239|    308|    h.write_u32_le(version.header()).unwrap();
  240|    308|    h.write_u32_le(version.version_group_id()).unwrap();
  241|    308|    h.write_u32_le(consensus_branch_id.into()).unwrap();
  242|    308|    h.write_u32_le(lock_time).unwrap();
  243|    308|    h.write_u32_le(expiry_height.into()).unwrap();
  244|       |
  245|       |    // TODO: Factor this out into a separate txid computation when implementing ZIP 246 in full.
  246|       |    #[cfg(all(zcash_unstable = "nu7", feature = "zip-233"))]
  247|       |    if version.has_zip233() {
  248|       |        h.write_u64_le((*zip233_amount).into()).unwrap();
  249|       |    }
  250|       |
  251|    308|    h.finalize()
  252|    308|}
