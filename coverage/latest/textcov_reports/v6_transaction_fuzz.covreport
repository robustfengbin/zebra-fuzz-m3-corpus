  342|   370k|    const fn montgomery_reduce(
  343|   370k|        r0: u64,
  344|   370k|        r1: u64,
  345|   370k|        r2: u64,
  346|   370k|        r3: u64,
  347|   370k|        r4: u64,
  348|   370k|        r5: u64,
  349|   370k|        r6: u64,
  350|   370k|        r7: u64,
  351|   370k|    ) -> Self {
  352|       |        // The Montgomery reduction here is based on Algorithm 14.32 in
  353|       |        // Handbook of Applied Cryptography
  354|       |        // <http://cacr.uwaterloo.ca/hac/about/chap14.pdf>.
  355|       |
  356|   370k|        let k = r0.wrapping_mul(INV);
  357|   370k|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  358|   370k|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  359|   370k|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  360|   370k|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  361|   370k|        let (r4, carry2) = adc(r4, 0, carry);
  362|       |
  363|   370k|        let k = r1.wrapping_mul(INV);
