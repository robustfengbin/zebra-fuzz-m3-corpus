  301|       |        // limb sizes, it's OK to do a "weak reduction", where we
  302|       |        // compute the carry-outs in parallel.
  303|       |
  304|     24|        let c0 = limbs[0] >> 51;
  305|     24|        let c1 = limbs[1] >> 51;
  306|     24|        let c2 = limbs[2] >> 51;
  307|     24|        let c3 = limbs[3] >> 51;
  308|     24|        let c4 = limbs[4] >> 51;
