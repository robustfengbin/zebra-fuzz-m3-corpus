  310|     24|        limbs[0] &= LOW_51_BIT_MASK;
  311|     24|        limbs[1] &= LOW_51_BIT_MASK;
  312|     24|        limbs[2] &= LOW_51_BIT_MASK;
  313|     24|        limbs[3] &= LOW_51_BIT_MASK;
  314|     24|        limbs[4] &= LOW_51_BIT_MASK;
