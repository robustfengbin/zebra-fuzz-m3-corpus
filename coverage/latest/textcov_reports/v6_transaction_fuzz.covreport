  260|    270|        h.write_all(d.prevouts_digest.as_bytes()).unwrap();
  261|    270|        h.write_all(d.sequence_digest.as_bytes()).unwrap();
  262|    270|        h.write_all(d.outputs_digest.as_bytes()).unwrap();
  263|    270|    }
  264|    308|    h.finalize()
  265|    308|}
