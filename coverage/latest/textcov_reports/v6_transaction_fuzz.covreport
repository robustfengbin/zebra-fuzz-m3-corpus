  148|     24|        writer.write_32_bytes(&self.nullifiers[0].into())?;
  149|     24|        writer.write_32_bytes(&self.nullifiers[1].into())?;
  150|     24|        writer.write_32_bytes(&self.commitments[0].into())?;
  151|     24|        writer.write_32_bytes(&self.commitments[1].into())?;
  152|       |
  153|     24|        writer.write_all(&self.ephemeral_key.as_bytes()[..])?;
