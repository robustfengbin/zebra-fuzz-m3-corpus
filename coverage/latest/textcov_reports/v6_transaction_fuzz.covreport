  143|     24|    fn zcash_serialize<W: io::Write>(&self, mut writer: W) -> Result<(), io::Error> {
  144|     24|        self.vpub_old.zcash_serialize(&mut writer)?;
  145|     24|        self.vpub_new.zcash_serialize(&mut writer)?;
  146|       |
