  342|  2.64M|    const fn montgomery_reduce(
  343|  2.64M|        r0: u64,
  344|  2.64M|        r1: u64,
  345|  2.64M|        r2: u64,
  346|  2.64M|        r3: u64,
  347|  2.64M|        r4: u64,
  348|  2.64M|        r5: u64,
  349|  2.64M|        r6: u64,
  350|  2.64M|        r7: u64,
  351|  2.64M|    ) -> Self {
  352|       |        // The Montgomery reduction here is based on Algorithm 14.32 in
  353|       |        // Handbook of Applied Cryptography
  354|       |        // <http://cacr.uwaterloo.ca/hac/about/chap14.pdf>.
  355|       |
  356|  2.64M|        let k = r0.wrapping_mul(INV);
  357|  2.64M|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  358|  2.64M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  359|  2.64M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  360|  2.64M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  361|  2.64M|        let (r4, carry2) = adc(r4, 0, carry);
  362|       |
  363|  2.64M|        let k = r1.wrapping_mul(INV);
  364|  2.64M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  365|  2.64M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  366|  2.64M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  367|  2.64M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  368|  2.64M|        let (r5, carry2) = adc(r5, carry2, carry);
  369|       |
  370|  2.64M|        let k = r2.wrapping_mul(INV);
  371|  2.64M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  372|  2.64M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  373|  2.64M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  374|  2.64M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  375|  2.64M|        let (r6, carry2) = adc(r6, carry2, carry);
  376|       |
  377|  2.64M|        let k = r3.wrapping_mul(INV);
  378|  2.64M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  379|  2.64M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  380|  2.64M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  381|  2.64M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  382|  2.64M|        let (r7, _) = adc(r7, carry2, carry);
