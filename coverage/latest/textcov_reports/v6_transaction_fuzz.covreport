  353|  13.7k|        let r5 = (r5 << 1) | (r4 >> 63);
  354|  13.7k|        let r4 = (r4 << 1) | (r3 >> 63);
  355|  13.7k|        let r3 = (r3 << 1) | (r2 >> 63);
  356|  13.7k|        let r2 = (r2 << 1) | (r1 >> 63);
  357|  13.7k|        let r1 = r1 << 1;
  358|       |
  359|  13.7k|        let (r0, carry) = mac(0, self.0[0], self.0[0], 0);
  360|  13.7k|        let (r1, carry) = adc(0, r1, carry);
  361|  13.7k|        let (r2, carry) = mac(r2, self.0[1], self.0[1], carry);
  362|  13.7k|        let (r3, carry) = adc(0, r3, carry);
  363|  13.7k|        let (r4, carry) = mac(r4, self.0[2], self.0[2], carry);
  364|  13.7k|        let (r5, carry) = adc(0, r5, carry);
  365|  13.7k|        let (r6, carry) = mac(r6, self.0[3], self.0[3], carry);
  366|  13.7k|        let (r7, _) = adc(0, r7, carry);
  367|       |
  368|  13.7k|        Scalar::montgomery_reduce(r0, r1, r2, r3, r4, r5, r6, r7)
