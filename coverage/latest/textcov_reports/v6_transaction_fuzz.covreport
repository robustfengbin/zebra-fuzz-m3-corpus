  316|     24|        limbs[0] += c4 * 19;
  317|     24|        limbs[1] += c0;
  318|     24|        limbs[2] += c1;
  319|     24|        limbs[3] += c2;
  320|     24|        limbs[4] += c3;
  321|       |
  322|     24|        FieldElement51(limbs)
