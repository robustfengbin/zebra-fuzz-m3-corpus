  159|     24|        self.vmacs[1].zcash_serialize(&mut writer)?;
  160|     24|        self.zkproof.zcash_serialize(&mut writer)?;
  161|       |
  162|     24|        self.enc_ciphertexts[0].zcash_serialize(&mut writer)?;
  163|     24|        self.enc_ciphertexts[1].zcash_serialize(&mut writer)?;
  164|       |
  165|     24|        Ok(())
  166|     24|    }
