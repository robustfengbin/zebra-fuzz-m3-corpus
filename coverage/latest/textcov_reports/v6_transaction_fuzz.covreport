  423|    308|pub(crate) fn to_hash_v6(
  424|    308|    consensus_branch_id: BranchId,
  425|    308|    header_digest: Blake2bHash,
  426|    308|    transparent_digest: Blake2bHash,
  427|    308|    sapling_digest: Option<Blake2bHash>,
  428|    308|    orchard_digest: Option<Blake2bHash>,
  429|    308|    ironwood_digest: Option<Blake2bHash>,
  430|    308|) -> Blake2bHash {
  431|    308|    let mut personal = [0; 16];
  432|    308|    personal[..12].copy_from_slice(ZCASH_TX_PERSONALIZATION_PREFIX);
  433|    308|    (&mut personal[12..])
  434|    308|        .write_u32_le(consensus_branch_id.into())
  435|    308|        .unwrap();
  436|       |
  437|    308|    let mut h = hasher(&personal);
  438|    308|    h.write_all(header_digest.as_bytes()).unwrap();
  439|    308|    h.write_all(transparent_digest.as_bytes()).unwrap();
  440|    308|    h.write_all(
  441|    308|        sapling_digest
  442|    308|            .unwrap_or_else(hash_sapling_txid_empty)
  443|    308|            .as_bytes(),
  444|       |    )
  445|    308|    .unwrap();
  446|    308|    h.write_all(
  447|    308|        orchard_digest
  448|    308|            .unwrap_or_else(|| {
  449|       |                let (value_pool, tx_version) = orchard_commitment_domain(TxVersion::V6);
  450|       |                orchard::commitments::hash_bundle_txid_empty(value_pool, tx_version)
  451|       |                    .expect("empty Orchard bundle txid commitment is valid for its tx format")
  452|       |            })
  453|    308|            .as_bytes(),
  454|       |    )
  455|    308|    .unwrap();
  456|    308|    h.write_all(
  457|    308|        ironwood_digest
  458|    308|            .unwrap_or_else(|| {
  459|       |                let (value_pool, tx_version) = ironwood_v6_domain();
  460|       |                orchard::commitments::hash_bundle_txid_empty(value_pool, tx_version)
  461|       |                    .expect("empty Ironwood bundle txid commitment is valid")
  462|       |            })
  463|    308|            .as_bytes(),
  464|       |    )
  465|    308|    .unwrap();
  466|       |
  467|    308|    h.finalize()
  468|    308|}
