 1454|     70|    pub(crate) const fn num_days_from_ce(&self) -> i32 {
 1455|       |        // we know this wouldn't overflow since year is limited to 1/2^13 of i32's full range.
 1456|     70|        let mut year = self.year() - 1;
 1457|     70|        let mut ndays = 0;
 1458|     70|        if year < 0 {
 1459|      0|            let excess = 1 + (-year) / 400;
 1460|      0|            year += excess * 400;
 1461|      0|            ndays -= excess * 146_097;
 1462|     70|        }
 1463|     70|        let div_100 = year / 100;
 1464|     70|        ndays += ((year * 1461) >> 2) - div_100 + (div_100 >> 2);
