_RNvXs4_NtNtCs2qdhHbQ3r3c_11zebra_chain7sapling6outputNtB5_21OutputInTransactionV4NtNtNtB9_13serialization17zcash_deserialize18TrustedPreallocate14max_allocation:
  263|  20.5k|    fn max_allocation() -> u64 {
  264|       |        // Since a serialized Vec<Output> uses at least one byte for its length,
  265|       |        // the max allocation can never exceed (MAX_BLOCK_BYTES - 1) / OUTPUT_SIZE
  266|       |        const MAX: u64 = (MAX_BLOCK_BYTES - 1) / OUTPUT_SIZE;
  267|       |        // # Consensus
  268|       |        //
  269|       |        // > [NU5 onward] nSpendsSapling, nOutputsSapling, and nActionsOrchard MUST all be less than 2^16.
  270|       |        //
  271|       |        // https://zips.z.cash/protocol/protocol.pdf#txnconsensus
  272|       |        //
  273|       |        // This acts as nOutputsSapling and is therefore subject to the rule.
  274|       |        // The maximum value is actually smaller due to the block size limit,
  275|       |        // but we ensure the 2^16 limit with a static assertion.
  276|       |        // (The check is not required pre-NU5, but it doesn't cause problems.)
  277|       |        static_assertions::const_assert!(MAX < (1 << 16));
  278|  20.5k|        MAX
  279|  20.5k|    }
_RNvXs5_NtNtCs2qdhHbQ3r3c_11zebra_chain7sapling6outputNtB5_27OutputPrefixInTransactionV5NtNtNtB9_13serialization17zcash_deserialize18TrustedPreallocate14max_allocation:
  283|  13.3k|    fn max_allocation() -> u64 {
  284|       |        // Since V4 and V5 have the same fields,
  285|       |        // and the V5 associated fields are required,
  286|       |        // a valid max allocation can never exceed this size
  287|  13.3k|        OutputInTransactionV4::max_allocation()
  288|  13.3k|    }

_RNvXs5_NtNtCs2qdhHbQ3r3c_11zebra_chain7sapling13shielded_dataNtNtNtNtB9_10primitives6proofs7groth1612Groth16ProofNtNtNtB9_13serialization17zcash_deserialize18TrustedPreallocate14max_allocation:
  366|  3.57k|    fn max_allocation() -> u64 {
  367|       |        // Each V5 transaction proof array entry must have a corresponding
  368|       |        // spend or output prefix. We use the larger limit, so we don't reject
  369|       |        // any valid large blocks.
  370|       |        //
  371|       |        // TODO: put a separate limit on proofs in spends and outputs
  372|  3.57k|        max(
  373|  3.57k|            SpendPrefixInTransactionV5::max_allocation(),
  374|  3.57k|            OutputPrefixInTransactionV5::max_allocation(),
  375|       |        )
  376|  3.57k|    }
