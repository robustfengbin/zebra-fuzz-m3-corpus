  613|  21.5k|    pub const fn neg(&self) -> Self {
  614|       |        // Subtract `self` from `MODULUS` to negate. Ignore the final
  615|       |        // borrow because it cannot underflow; self is guaranteed to
  616|       |        // be in the field.
  617|  21.5k|        let (d0, borrow) = sbb(MODULUS.0[0], self.0[0], 0);
  618|  21.5k|        let (d1, borrow) = sbb(MODULUS.0[1], self.0[1], borrow);
  619|  21.5k|        let (d2, borrow) = sbb(MODULUS.0[2], self.0[2], borrow);
  620|  21.5k|        let (d3, _) = sbb(MODULUS.0[3], self.0[3], borrow);
  621|       |
  622|       |        // `tmp` could be `MODULUS` if `self` was zero. Create a mask that is
  623|       |        // zero if `self` was zero, and `u64::max_value()` if self was nonzero.
  624|  21.5k|        let mask = (((self.0[0] | self.0[1] | self.0[2] | self.0[3]) == 0) as u64).wrapping_sub(1);
  625|       |
  626|  21.5k|        Scalar([d0 & mask, d1 & mask, d2 & mask, d3 & mask])
  627|  21.5k|    }
