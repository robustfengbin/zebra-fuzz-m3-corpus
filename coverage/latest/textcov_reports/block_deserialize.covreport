  582|   574k|    pub const fn sub(&self, rhs: &Self) -> Self {
  583|   574k|        let (d0, borrow) = sbb(self.0[0], rhs.0[0], 0);
  584|   574k|        let (d1, borrow) = sbb(self.0[1], rhs.0[1], borrow);
  585|   574k|        let (d2, borrow) = sbb(self.0[2], rhs.0[2], borrow);
  586|   574k|        let (d3, borrow) = sbb(self.0[3], rhs.0[3], borrow);
  587|       |
  588|       |        // If underflow occurred on the final limb, borrow = 0xfff...fff, otherwise
  589|       |        // borrow = 0x000...000. Thus, we use it as a mask to conditionally add the modulus.
  590|   574k|        let (d0, carry) = adc(d0, MODULUS.0[0] & borrow, 0);
  591|   574k|        let (d1, carry) = adc(d1, MODULUS.0[1] & borrow, carry);
  592|   574k|        let (d2, carry) = adc(d2, MODULUS.0[2] & borrow, carry);
  593|   574k|        let (d3, _) = adc(d3, MODULUS.0[3] & borrow, carry);
  594|       |
  595|   574k|        Scalar([d0, d1, d2, d3])
  596|   574k|    }
