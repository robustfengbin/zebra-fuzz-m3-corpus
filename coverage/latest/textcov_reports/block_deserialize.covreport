  506|  6.55M|    const fn montgomery_reduce(
  507|  6.55M|        r0: u64,
  508|  6.55M|        r1: u64,
  509|  6.55M|        r2: u64,
  510|  6.55M|        r3: u64,
  511|  6.55M|        r4: u64,
  512|  6.55M|        r5: u64,
  513|  6.55M|        r6: u64,
  514|  6.55M|        r7: u64,
  515|  6.55M|    ) -> Self {
  516|       |        // The Montgomery reduction here is based on Algorithm 14.32 in
  517|       |        // Handbook of Applied Cryptography
  518|       |        // <http://cacr.uwaterloo.ca/hac/about/chap14.pdf>.
  519|       |
  520|  6.55M|        let k = r0.wrapping_mul(INV);
  521|  6.55M|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  522|  6.55M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  523|  6.55M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  524|  6.55M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  525|  6.55M|        let (r4, carry2) = adc(r4, 0, carry);
  526|       |
  527|  6.55M|        let k = r1.wrapping_mul(INV);
  528|  6.55M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  529|  6.55M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  530|  6.55M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  531|  6.55M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  532|  6.55M|        let (r5, carry2) = adc(r5, carry2, carry);
  533|       |
  534|  6.55M|        let k = r2.wrapping_mul(INV);
  535|  6.55M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  536|  6.55M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  537|  6.55M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  538|  6.55M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  539|  6.55M|        let (r6, carry2) = adc(r6, carry2, carry);
  540|       |
  541|  6.55M|        let k = r3.wrapping_mul(INV);
  542|  6.55M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  543|  6.55M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  544|  6.55M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  545|  6.55M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  546|  6.55M|        let (r7, _) = adc(r7, carry2, carry);
  547|       |
  548|       |        // Result may be within MODULUS of the correct value
  549|  6.55M|        (&Scalar([r4, r5, r6, r7])).sub(&MODULUS)
  550|  6.55M|    }
