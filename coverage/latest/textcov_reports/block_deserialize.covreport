  618|  4.45k|        let (d1, borrow) = sbb(MODULUS.0[1], self.0[1], borrow);
  619|  4.45k|        let (d2, borrow) = sbb(MODULUS.0[2], self.0[2], borrow);
  620|  4.45k|        let (d3, _) = sbb(MODULUS.0[3], self.0[3], borrow);
  621|       |
  622|       |        // `tmp` could be `MODULUS` if `self` was zero. Create a mask that is
  623|       |        // zero if `self` was zero, and `u64::max_value()` if self was nonzero.
  624|  4.45k|        let mask = (((self.0[0] | self.0[1] | self.0[2] | self.0[3]) == 0) as u64).wrapping_sub(1);
  625|       |
  626|  4.45k|        Scalar([d0 & mask, d1 & mask, d2 & mask, d3 & mask])
  627|  4.45k|    }
