   88|      0|                    ));
   89|     58|                }
   90|     58|                rk_bytes.into()
   91|       |            },
   92|       |            // Type is `{0 .. 𝑞_ℙ − 1}`. Note that the second rule quoted above
   93|       |            // is also enforced here and it is technically redundant with the first.
   94|       |            // See [`pallas::Base::zcash_deserialize`].
   95|     58|            cm_x: pallas::Base::zcash_deserialize(&mut reader)?,
