  356|  3.21M|        let k = r0.wrapping_mul(INV);
  357|  3.21M|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  358|  3.21M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  359|  3.21M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  360|  3.21M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  361|  3.21M|        let (r4, carry2) = adc(r4, 0, carry);
  362|       |
  363|  3.21M|        let k = r1.wrapping_mul(INV);
  364|  3.21M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  365|  3.21M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  366|  3.21M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  367|  3.21M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  368|  3.21M|        let (r5, carry2) = adc(r5, carry2, carry);
  369|       |
  370|  3.21M|        let k = r2.wrapping_mul(INV);
  371|  3.21M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  372|  3.21M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  373|  3.21M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  374|  3.21M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  375|  3.21M|        let (r6, carry2) = adc(r6, carry2, carry);
  376|       |
  377|  3.21M|        let k = r3.wrapping_mul(INV);
  378|  3.21M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  379|  3.21M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  380|  3.21M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  381|  3.21M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  382|  3.21M|        let (r7, _) = adc(r7, carry2, carry);
