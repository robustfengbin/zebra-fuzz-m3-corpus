  161|       |
  162|    744|        self.enc_ciphertexts[0].zcash_serialize(&mut writer)?;
  163|    744|        self.enc_ciphertexts[1].zcash_serialize(&mut writer)?;
  164|       |
  165|    744|        Ok(())
  166|    744|    }
