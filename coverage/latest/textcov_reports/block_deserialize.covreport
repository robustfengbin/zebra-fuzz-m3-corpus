  179|  21.5k|        let mut res = Self::ONE;
  180|  86.3k|        for e in exp.as_ref().iter().rev() {
  181|  5.52M|            for i in (0..64).rev() {
  182|  5.52M|                res = res.square();
  183|       |
  184|  5.52M|                if ((*e >> i) & 1) == 1 {
  185|  2.84M|                    res.mul_assign(self);
  186|  2.84M|                }
  187|       |            }
