  408|  31.2k|    pub fn invert(&self) -> CtOption<Self> {
  409|       |        #[inline(always)]
  410|       |        fn square_assign_multi(n: &mut Scalar, num_times: usize) {
  411|       |            for _ in 0..num_times {
  412|       |                *n = n.square();
  413|       |            }
  414|       |        }
  415|       |        // found using https://github.com/kwantam/addchain
  416|  31.2k|        let mut t0 = self.square();
  417|  31.2k|        let mut t1 = t0 * self;
  418|  31.2k|        let mut t16 = t0.square();
  419|  31.2k|        let mut t6 = t16.square();
  420|  31.2k|        let mut t5 = t6 * t0;
  421|  31.2k|        t0 = t6 * t16;
  422|  31.2k|        let mut t12 = t5 * t16;
  423|  31.2k|        let mut t2 = t6.square();
  424|  31.2k|        let mut t7 = t5 * t6;
  425|  31.2k|        let mut t15 = t0 * t5;
  426|  31.2k|        let mut t17 = t12.square();
  427|  31.2k|        t1 *= t17;
  428|  31.2k|        let mut t3 = t7 * t2;
  429|  31.2k|        let t8 = t1 * t17;
  430|  31.2k|        let t4 = t8 * t2;
  431|  31.2k|        let t9 = t8 * t7;
  432|  31.2k|        t7 = t4 * t5;
  433|  31.2k|        let t11 = t4 * t17;
  434|  31.2k|        t5 = t9 * t17;
  435|  31.2k|        let t14 = t7 * t15;
  436|  31.2k|        let t13 = t11 * t12;
  437|  31.2k|        t12 = t11 * t17;
  438|  31.2k|        t15 *= &t12;
  439|  31.2k|        t16 *= &t15;
  440|  31.2k|        t3 *= &t16;
  441|  31.2k|        t17 *= &t3;
  442|  31.2k|        t0 *= &t17;
  443|  31.2k|        t6 *= &t0;
  444|  31.2k|        t2 *= &t6;
  445|  31.2k|        square_assign_multi(&mut t0, 8);
  446|  31.2k|        t0 *= &t17;
  447|  31.2k|        square_assign_multi(&mut t0, 9);
  448|  31.2k|        t0 *= &t16;
  449|  31.2k|        square_assign_multi(&mut t0, 9);
  450|  31.2k|        t0 *= &t15;
  451|  31.2k|        square_assign_multi(&mut t0, 9);
  452|  31.2k|        t0 *= &t15;
