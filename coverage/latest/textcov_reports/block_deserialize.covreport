  520|  31.1M|        let k = r0.wrapping_mul(INV);
  521|  31.1M|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  522|  31.1M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  523|  31.1M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  524|  31.1M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  525|  31.1M|        let (r4, carry2) = adc(r4, 0, carry);
  526|       |
  527|  31.1M|        let k = r1.wrapping_mul(INV);
  528|  31.1M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  529|  31.1M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  530|  31.1M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  531|  31.1M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  532|  31.1M|        let (r5, carry2) = adc(r5, carry2, carry);
  533|       |
  534|  31.1M|        let k = r2.wrapping_mul(INV);
  535|  31.1M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  536|  31.1M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  537|  31.1M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  538|  31.1M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  539|  31.1M|        let (r6, carry2) = adc(r6, carry2, carry);
  540|       |
  541|  31.1M|        let k = r3.wrapping_mul(INV);
  542|  31.1M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  543|  31.1M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  544|  31.1M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  545|  31.1M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  546|  31.1M|        let (r7, _) = adc(r7, carry2, carry);
  547|       |
  548|       |        // Result may be within MODULUS of the correct value
  549|  31.1M|        (&Scalar([r4, r5, r6, r7])).sub(&MODULUS)
  550|  31.1M|    }
