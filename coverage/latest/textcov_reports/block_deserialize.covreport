  563|   169k|        let (r2, carry) = mac(r2, self.0[1], rhs.0[1], carry);
  564|   169k|        let (r3, carry) = mac(r3, self.0[1], rhs.0[2], carry);
  565|   169k|        let (r4, r5) = mac(r4, self.0[1], rhs.0[3], carry);
  566|       |
  567|   169k|        let (r2, carry) = mac(r2, self.0[2], rhs.0[0], 0);
  568|   169k|        let (r3, carry) = mac(r3, self.0[2], rhs.0[1], carry);
  569|   169k|        let (r4, carry) = mac(r4, self.0[2], rhs.0[2], carry);
  570|   169k|        let (r5, r6) = mac(r5, self.0[2], rhs.0[3], carry);
  571|       |
