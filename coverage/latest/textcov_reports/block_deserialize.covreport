  592|   119k|        let (d2, carry) = adc(d2, MODULUS.0[2] & borrow, carry);
  593|   119k|        let (d3, _) = adc(d3, MODULUS.0[3] & borrow, carry);
  594|       |
  595|   119k|        Scalar([d0, d1, d2, d3])
  596|   119k|    }
