  582|   119k|    pub const fn sub(&self, rhs: &Self) -> Self {
  583|   119k|        let (d0, borrow) = sbb(self.0[0], rhs.0[0], 0);
  584|   119k|        let (d1, borrow) = sbb(self.0[1], rhs.0[1], borrow);
  585|   119k|        let (d2, borrow) = sbb(self.0[2], rhs.0[2], borrow);
