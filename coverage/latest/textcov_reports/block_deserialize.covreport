  241|  13.2k|    h.write_u32_le(consensus_branch_id.into()).unwrap();
  242|  13.2k|    h.write_u32_le(lock_time).unwrap();
  243|  13.2k|    h.write_u32_le(expiry_height.into()).unwrap();
