   29|  29.3k|            let tail_ptr = data.as_ptr().add(blocks_len);
   30|  29.3k|            (
   31|  29.3k|                slice::from_raw_parts(blocks_ptr, nb),
   32|  29.3k|                slice::from_raw_parts(tail_ptr, tail_len),
   33|  29.3k|            )
   34|       |        }
   35|  29.3k|    }

