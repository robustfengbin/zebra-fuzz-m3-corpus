  341|   157k|    pub const fn square(&self) -> Scalar {
  342|   157k|        let (r1, carry) = mac(0, self.0[0], self.0[1], 0);
  343|   157k|        let (r2, carry) = mac(0, self.0[0], self.0[2], carry);
  344|   157k|        let (r3, r4) = mac(0, self.0[0], self.0[3], carry);
  345|       |
  346|   157k|        let (r3, carry) = mac(r3, self.0[1], self.0[2], 0);
  347|   157k|        let (r4, r5) = mac(r4, self.0[1], self.0[3], carry);
  348|       |
  349|   157k|        let (r5, r6) = mac(r5, self.0[2], self.0[3], 0);
  350|       |
  351|   157k|        let r7 = r6 >> 63;
  352|   157k|        let r6 = (r6 << 1) | (r5 >> 63);
  353|   157k|        let r5 = (r5 << 1) | (r4 >> 63);
  354|   157k|        let r4 = (r4 << 1) | (r3 >> 63);
  355|   157k|        let r3 = (r3 << 1) | (r2 >> 63);
  356|   157k|        let r2 = (r2 << 1) | (r1 >> 63);
  357|   157k|        let r1 = r1 << 1;
  358|       |
  359|   157k|        let (r0, carry) = mac(0, self.0[0], self.0[0], 0);
  360|   157k|        let (r1, carry) = adc(0, r1, carry);
  361|   157k|        let (r2, carry) = mac(r2, self.0[1], self.0[1], carry);
  362|   157k|        let (r3, carry) = adc(0, r3, carry);
  363|   157k|        let (r4, carry) = mac(r4, self.0[2], self.0[2], carry);
  364|   157k|        let (r5, carry) = adc(0, r5, carry);
  365|   157k|        let (r6, carry) = mac(r6, self.0[3], self.0[3], carry);
  366|   157k|        let (r7, _) = adc(0, r7, carry);
  367|       |
  368|   157k|        Scalar::montgomery_reduce(r0, r1, r2, r3, r4, r5, r6, r7)
  369|   157k|    }
