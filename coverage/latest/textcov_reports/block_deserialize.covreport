   18|  21.5k|pub fn sqrt_tonelli_shanks<F: PrimeField, S: AsRef<[u64]>>(f: &F, tm1d2: S) -> CtOption<F> {
   19|       |    // This is a constant-time version of https://eprint.iacr.org/2012/685.pdf (page 12,
   20|       |    // algorithm 5). Steps 2-5 of the algorithm are omitted because they are only needed
   21|       |    // to detect non-square input; it is more efficient to do that by checking at the end
   22|       |    // whether the square of the result is the input.
   23|       |
   24|       |    // w = self^((t - 1) // 2)
   25|  21.5k|    let w = f.pow_vartime(tm1d2);
   26|       |
   27|  21.5k|    let mut v = F::S;
   28|  21.5k|    let mut x = w * f;
   29|  21.5k|    let mut b = x * w;
   30|       |
   31|       |    // Initialize z as the 2^S root of unity.
   32|  21.5k|    let mut z = F::ROOT_OF_UNITY;
   33|       |
   34|   690k|    for max_v in (1..=F::S).rev() {
   35|   690k|        let mut k = 1;
   36|   690k|        let mut b2k = b.square();
   37|   690k|        let mut j_less_than_v: Choice = 1.into();
   38|       |
   39|       |        // This loop has three phases based on the value of k for algorithm 5:
   40|       |        // - for j <= k, we square b2k in order to calculate b^{2^k}.
   41|       |        // - for k < j <= v, we square z in order to calculate ω.
   42|       |        // - for j > v, we do nothing.
   43|  10.0M|        for j in 2..max_v {
   44|  10.0M|            let b2k_is_one = b2k.ct_eq(&F::ONE);
   45|  10.0M|            let squared = F::conditional_select(&b2k, &z, b2k_is_one).square();
   46|  10.0M|            b2k = F::conditional_select(&squared, &b2k, b2k_is_one);
   47|  10.0M|            let new_z = F::conditional_select(&z, &squared, b2k_is_one);
   48|  10.0M|            j_less_than_v &= !j.ct_eq(&v);
   49|  10.0M|            k = u32::conditional_select(&j, &k, b2k_is_one);
   50|  10.0M|            z = F::conditional_select(&z, &new_z, j_less_than_v);
   51|  10.0M|        }
   52|       |
   53|   690k|        let result = x * z;
   54|   690k|        x = F::conditional_select(&result, &x, b.ct_eq(&F::ONE));
   55|   690k|        z = z.square();
   56|   690k|        b *= z;
   57|   690k|        v = k;
   58|       |    }
   59|       |
   60|  21.5k|    CtOption::new(
   61|  21.5k|        x,
   62|  21.5k|        (x * x).ct_eq(f), // Only return Some if it's the square root.
   63|       |    )
   64|  21.5k|}

