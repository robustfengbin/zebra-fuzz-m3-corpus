  203|     98|            vpub_old: (&mut reader).zcash_deserialize_into()?,
  204|     98|            vpub_new: (&mut reader).zcash_deserialize_into()?,
  205|       |            // Type is `B^{ℓ^{Sprout}_{Merkle}}` i.e. 32 bytes.
  206|     98|            anchor: tree::Root::from(reader.read_32_bytes()?),
  207|       |            // Types are `B^{ℓ^{Sprout}_{PRF}}` i.e. 32 bytes.
  208|       |            nullifiers: [
  209|     98|                reader.read_32_bytes()?.into(),
  210|     98|                reader.read_32_bytes()?.into(),
  211|       |            ],
  212|       |            // Types are `NoteCommit^{Sprout}.Output`, i.e. `B^{ℓ^{Sprout}_{Merkle}}`,
  213|       |            // i.e. 32 bytes. https://zips.z.cash/protocol/protocol.pdf#abstractcommit
  214|       |            commitments: [
  215|     98|                commitment::NoteCommitment::from(reader.read_32_bytes()?),
  216|     98|                commitment::NoteCommitment::from(reader.read_32_bytes()?),
  217|       |            ],
  218|       |            // Type is `KA^{Sprout}.Public`, i.e. `B^Y^{[32]}`, i.e. 32 bytes.
  219|       |            // https://zips.z.cash/protocol/protocol.pdf#concretesproutkeyagreement
  220|     98|            ephemeral_key: x25519_dalek::PublicKey::from(reader.read_32_bytes()?),
  221|       |            // Type is `B^{[ℓ_{Seed}]}`, i.e. 32 bytes
  222|     98|            random_seed: RandomSeed::from(reader.read_32_bytes()?),
  223|       |            // Types are `B^{ℓ^{Sprout}_{PRF}}` i.e. 32 bytes.
  224|       |            // See [`note::Mac::zcash_deserialize`].
  225|       |            vmacs: [
  226|     98|                note::Mac::zcash_deserialize(&mut reader)?,
  227|     98|                note::Mac::zcash_deserialize(&mut reader)?,
