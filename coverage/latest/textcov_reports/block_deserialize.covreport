  557|  36.2k|        let (r0, carry) = mac(0, self.0[0], rhs.0[0], 0);
  558|  36.2k|        let (r1, carry) = mac(0, self.0[0], rhs.0[1], carry);
  559|  36.2k|        let (r2, carry) = mac(0, self.0[0], rhs.0[2], carry);
