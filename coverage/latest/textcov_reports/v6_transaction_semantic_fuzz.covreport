_RNvMse_NtNtCs41Au54XfBWR_12pasta_curves6fields2fpNtB5_2Fp17montgomery_reduce:
  342|   511k|    const fn montgomery_reduce(
  343|   511k|        r0: u64,
  344|   511k|        r1: u64,
  345|   511k|        r2: u64,
  346|   511k|        r3: u64,
  347|   511k|        r4: u64,
  348|   511k|        r5: u64,
  349|   511k|        r6: u64,
  350|   511k|        r7: u64,
  351|   511k|    ) -> Self {
  352|       |        // The Montgomery reduction here is based on Algorithm 14.32 in
  353|       |        // Handbook of Applied Cryptography
  354|       |        // <http://cacr.uwaterloo.ca/hac/about/chap14.pdf>.
  355|       |
