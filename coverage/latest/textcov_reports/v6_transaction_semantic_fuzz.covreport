  347|  17.7k|        let (r4, r5) = mac(r4, self.0[1], self.0[3], carry);
  348|       |
  349|  17.7k|        let (r5, r6) = mac(r5, self.0[2], self.0[3], 0);
  350|       |
  351|  17.7k|        let r7 = r6 >> 63;
  352|  17.7k|        let r6 = (r6 << 1) | (r5 >> 63);
  353|  17.7k|        let r5 = (r5 << 1) | (r4 >> 63);
  354|  17.7k|        let r4 = (r4 << 1) | (r3 >> 63);
  355|  17.7k|        let r3 = (r3 << 1) | (r2 >> 63);
  356|  17.7k|        let r2 = (r2 << 1) | (r1 >> 63);
  357|  17.7k|        let r1 = r1 << 1;
