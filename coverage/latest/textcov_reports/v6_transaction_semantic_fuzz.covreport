 1454|      5|    pub(crate) const fn num_days_from_ce(&self) -> i32 {
 1455|       |        // we know this wouldn't overflow since year is limited to 1/2^13 of i32's full range.
 1456|      5|        let mut year = self.year() - 1;
 1457|      5|        let mut ndays = 0;
 1458|      5|        if year < 0 {
 1459|      0|            let excess = 1 + (-year) / 400;
 1460|      0|            year += excess * 400;
 1461|      0|            ndays -= excess * 146_097;
 1462|      5|        }
 1463|      5|        let div_100 = year / 100;
 1464|      5|        ndays += ((year * 1461) >> 2) - div_100 + (div_100 >> 2);
 1465|      5|        ndays + self.ordinal() as i32
 1466|      5|    }
_RNvMNtNtCs8jXVBPYSQuE_6chrono5naive4dateNtB2_9NaiveDate22from_ordinal_and_flags:
  130|     69|    const fn from_ordinal_and_flags(
  131|     69|        year: i32,
  132|     69|        ordinal: u32,
  133|     69|        flags: YearFlags,
  134|     69|    ) -> Option<NaiveDate> {
  135|     69|        if year < MIN_YEAR || year > MAX_YEAR {
  136|      0|            return None; // Out-of-range
  137|     69|        }
  138|     69|        if ordinal == 0 || ordinal > 366 {
  139|      0|            return None; // Invalid
  140|     69|        }
  141|     69|        debug_assert!(YearFlags::from_year(year).0 == flags.0);
  142|     69|        let yof = (year << 13) | (ordinal << 4) as i32 | flags.0 as i32;
  143|     69|        match yof & OL_MASK <= MAX_OL {
  144|     69|            true => Some(NaiveDate::from_yof(yof)),
  145|      0|            false => None, // Does not exist: Ordinal 366 in a common year.
  146|       |        }
  147|     69|    }
