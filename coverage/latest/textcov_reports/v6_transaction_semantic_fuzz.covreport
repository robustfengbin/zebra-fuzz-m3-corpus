  520|  1.43M|        let k = r0.wrapping_mul(INV);
  521|  1.43M|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  522|  1.43M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  523|  1.43M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  524|  1.43M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  525|  1.43M|        let (r4, carry2) = adc(r4, 0, carry);
  526|       |
  527|  1.43M|        let k = r1.wrapping_mul(INV);
  528|  1.43M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  529|  1.43M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  530|  1.43M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  531|  1.43M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  532|  1.43M|        let (r5, carry2) = adc(r5, carry2, carry);
  533|       |
  534|  1.43M|        let k = r2.wrapping_mul(INV);
  535|  1.43M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  536|  1.43M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  537|  1.43M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  538|  1.43M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  539|  1.43M|        let (r6, carry2) = adc(r6, carry2, carry);
  540|       |
  541|  1.43M|        let k = r3.wrapping_mul(INV);
  542|  1.43M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  543|  1.43M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  544|  1.43M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  545|  1.43M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
