  508|  3.31M|        r1: u64,
  509|  3.31M|        r2: u64,
  510|  3.31M|        r3: u64,
  511|  3.31M|        r4: u64,
  512|  3.31M|        r5: u64,
  513|  3.31M|        r6: u64,
  514|  3.31M|        r7: u64,
  515|  3.31M|    ) -> Self {
  516|       |        // The Montgomery reduction here is based on Algorithm 14.32 in
  517|       |        // Handbook of Applied Cryptography
  518|       |        // <http://cacr.uwaterloo.ca/hac/about/chap14.pdf>.
  519|       |
  520|  3.31M|        let k = r0.wrapping_mul(INV);
  521|  3.31M|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  522|  3.31M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  523|  3.31M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  524|  3.31M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  525|  3.31M|        let (r4, carry2) = adc(r4, 0, carry);
  526|       |
  527|  3.31M|        let k = r1.wrapping_mul(INV);
  528|  3.31M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  529|  3.31M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  530|  3.31M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  531|  3.31M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  532|  3.31M|        let (r5, carry2) = adc(r5, carry2, carry);
  533|       |
  534|  3.31M|        let k = r2.wrapping_mul(INV);
  535|  3.31M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  536|  3.31M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  537|  3.31M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  538|  3.31M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  539|  3.31M|        let (r6, carry2) = adc(r6, carry2, carry);
  540|       |
  541|  3.31M|        let k = r3.wrapping_mul(INV);
  542|  3.31M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  543|  3.31M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  544|  3.31M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  545|  3.31M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  546|  3.31M|        let (r7, _) = adc(r7, carry2, carry);
  547|       |
  548|       |        // Result may be within MODULUS of the correct value
  549|  3.31M|        (&Scalar([r4, r5, r6, r7])).sub(&MODULUS)
  550|  3.31M|    }
