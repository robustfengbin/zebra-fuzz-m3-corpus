  200|  4.36k|    fn sqrt_common(&self, uv: &F, v: &F) -> F {
  201|  4.36k|        let sqr = |x: F, i: u32| (0..i).fold(x, |x, _| x.square());
  202|  4.36k|        let inv = |x: F| self.inv[self.hasher.hash(&x)] as usize;
  203|       |
  204|  4.36k|        let x3 = *uv * v;
  205|  4.36k|        let x2 = sqr(x3, 8);
  206|  4.36k|        let x1 = sqr(x2, 8);
  207|  4.36k|        let x0 = sqr(x1, 8);
  208|       |
  209|       |        // i = 0, 1
  210|  4.36k|        let mut t_ = inv(x0); // = t >> 16
  211|       |                              // 1 == x0 * ROOT_OF_UNITY^(t_ << 24)
  212|  4.36k|        assert!(t_ < 0x100);
  213|  4.36k|        let alpha = x1 * self.g2[t_];
  214|       |
  215|       |        // i = 2
  216|  4.36k|        t_ += inv(alpha) << 8; // = t >> 8
  217|       |                               // 1 == x1 * ROOT_OF_UNITY^(t_ << 16)
  218|  4.36k|        assert!(t_ < 0x10000);
  219|  4.36k|        let alpha = x2 * self.g1[t_ & 0xFF] * self.g2[t_ >> 8];
  220|       |
  221|       |        // i = 3
  222|  4.36k|        t_ += inv(alpha) << 16; // = t
  223|       |                                // 1 == x2 * ROOT_OF_UNITY^(t_ << 8)
  224|  4.36k|        assert!(t_ < 0x1000000);
  225|  4.36k|        let alpha = x3 * self.g0[t_ & 0xFF] * self.g1[(t_ >> 8) & 0xFF] * self.g2[t_ >> 16];
  226|       |
  227|  4.36k|        t_ += inv(alpha) << 24; // = t << 1
  228|       |                                // 1 == x3 * ROOT_OF_UNITY^t_
  229|  4.36k|        t_ = (((t_ as u64) + 1) >> 1) as usize;
  230|  4.36k|        assert!(t_ <= 0x80000000);
  231|       |
  232|  4.36k|        *uv * self.g0[t_ & 0xFF]
  233|  4.36k|            * self.g1[(t_ >> 8) & 0xFF]
  234|  4.36k|            * self.g2[(t_ >> 16) & 0xFF]
  235|  4.36k|            * self.g3[t_ >> 24]
  236|  4.36k|    }
