_RNvNtNtCsblBBgngKd3Y_16zcash_primitives11transaction4txid10to_hash_v6:
  423|    253|pub(crate) fn to_hash_v6(
  424|    253|    consensus_branch_id: BranchId,
  425|    253|    header_digest: Blake2bHash,
  426|    253|    transparent_digest: Blake2bHash,
  427|    253|    sapling_digest: Option<Blake2bHash>,
  428|    253|    orchard_digest: Option<Blake2bHash>,
  429|    253|    ironwood_digest: Option<Blake2bHash>,
  430|    253|) -> Blake2bHash {
  431|    253|    let mut personal = [0; 16];
  432|    253|    personal[..12].copy_from_slice(ZCASH_TX_PERSONALIZATION_PREFIX);
  433|    253|    (&mut personal[12..])
  434|    253|        .write_u32_le(consensus_branch_id.into())
  435|    253|        .unwrap();
  436|       |
  437|    253|    let mut h = hasher(&personal);
  438|    253|    h.write_all(header_digest.as_bytes()).unwrap();
  439|    253|    h.write_all(transparent_digest.as_bytes()).unwrap();
  440|    253|    h.write_all(
  441|    253|        sapling_digest
  442|    253|            .unwrap_or_else(hash_sapling_txid_empty)
  443|    253|            .as_bytes(),
  444|       |    )
  445|    253|    .unwrap();
  446|    253|    h.write_all(
  447|    253|        orchard_digest
  448|    253|            .unwrap_or_else(|| {
  449|       |                let (value_pool, tx_version) = orchard_commitment_domain(TxVersion::V6);
  450|       |                orchard::commitments::hash_bundle_txid_empty(value_pool, tx_version)
  451|       |                    .expect("empty Orchard bundle txid commitment is valid for its tx format")
  452|       |            })
  453|    253|            .as_bytes(),
  454|       |    )
  455|    253|    .unwrap();
  456|    253|    h.write_all(
  457|    253|        ironwood_digest
  458|    253|            .unwrap_or_else(|| {
  459|       |                let (value_pool, tx_version) = ironwood_v6_domain();
  460|       |                orchard::commitments::hash_bundle_txid_empty(value_pool, tx_version)
  461|       |                    .expect("empty Ironwood bundle txid commitment is valid")
  462|       |            })
  463|    253|            .as_bytes(),
  464|       |    )
  465|    253|    .unwrap();
  466|       |
  467|    253|    h.finalize()
  468|    253|}
