  341|  7.79k|    pub const fn square(&self) -> Scalar {
  342|  7.79k|        let (r1, carry) = mac(0, self.0[0], self.0[1], 0);
  343|  7.79k|        let (r2, carry) = mac(0, self.0[0], self.0[2], carry);
  344|  7.79k|        let (r3, r4) = mac(0, self.0[0], self.0[3], carry);
  345|       |
  346|  7.79k|        let (r3, carry) = mac(r3, self.0[1], self.0[2], 0);
  347|  7.79k|        let (r4, r5) = mac(r4, self.0[1], self.0[3], carry);
  348|       |
  349|  7.79k|        let (r5, r6) = mac(r5, self.0[2], self.0[3], 0);
  350|       |
  351|  7.79k|        let r7 = r6 >> 63;
  352|  7.79k|        let r6 = (r6 << 1) | (r5 >> 63);
  353|  7.79k|        let r5 = (r5 << 1) | (r4 >> 63);
  354|  7.79k|        let r4 = (r4 << 1) | (r3 >> 63);
  355|  7.79k|        let r3 = (r3 << 1) | (r2 >> 63);
  356|  7.79k|        let r2 = (r2 << 1) | (r1 >> 63);
  357|  7.79k|        let r1 = r1 << 1;
