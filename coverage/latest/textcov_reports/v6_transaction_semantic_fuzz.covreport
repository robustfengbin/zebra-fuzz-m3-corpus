  256|  3.35k|    pub fn from_bytes(bytes: &[u8; 32]) -> CtOption<Scalar> {
  257|  3.35k|        let mut tmp = Scalar([0, 0, 0, 0]);
  258|       |
  259|  3.35k|        tmp.0[0] = u64::from_le_bytes(<[u8; 8]>::try_from(&bytes[0..8]).unwrap());
  260|  3.35k|        tmp.0[1] = u64::from_le_bytes(<[u8; 8]>::try_from(&bytes[8..16]).unwrap());
  261|  3.35k|        tmp.0[2] = u64::from_le_bytes(<[u8; 8]>::try_from(&bytes[16..24]).unwrap());
  262|  3.35k|        tmp.0[3] = u64::from_le_bytes(<[u8; 8]>::try_from(&bytes[24..32]).unwrap());
  263|       |
  264|       |        // Try to subtract the modulus
  265|  3.35k|        let (_, borrow) = sbb(tmp.0[0], MODULUS.0[0], 0);
  266|  3.35k|        let (_, borrow) = sbb(tmp.0[1], MODULUS.0[1], borrow);
  267|  3.35k|        let (_, borrow) = sbb(tmp.0[2], MODULUS.0[2], borrow);
  268|  3.35k|        let (_, borrow) = sbb(tmp.0[3], MODULUS.0[3], borrow);
  269|       |
