  211|       |                              // 1 == x0 * ROOT_OF_UNITY^(t_ << 24)
  212|  1.53k|        assert!(t_ < 0x100);
  213|  1.53k|        let alpha = x1 * self.g2[t_];
  214|       |
  215|       |        // i = 2
  216|  1.53k|        t_ += inv(alpha) << 8; // = t >> 8
  217|       |                               // 1 == x1 * ROOT_OF_UNITY^(t_ << 16)
  218|  1.53k|        assert!(t_ < 0x10000);
  219|  1.53k|        let alpha = x2 * self.g1[t_ & 0xFF] * self.g2[t_ >> 8];
  220|       |
