  229|    253|fn hash_header_txid_data(
  230|    253|    version: TxVersion,
  231|    253|    // we commit to the consensus branch ID with the header
  232|    253|    consensus_branch_id: BranchId,
  233|    253|    lock_time: u32,
  234|    253|    expiry_height: BlockHeight,
  235|    253|    #[cfg(all(zcash_unstable = "nu7", feature = "zip-233"))] zip233_amount: &Zatoshis,
