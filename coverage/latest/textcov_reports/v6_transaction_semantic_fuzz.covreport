  111|      1|            g1: gtab_1.into_boxed_slice().try_into().unwrap(),
  112|      1|            g2: gtab_2.into_boxed_slice().try_into().unwrap(),
  113|      1|            g3: gtab_3.into_boxed_slice().try_into().unwrap(),
