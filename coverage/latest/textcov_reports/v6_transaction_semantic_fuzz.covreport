  382|     69|        let (year_mod_400, ordinal) = cycle_to_yo(cycle as u32);
  383|     69|        let flags = YearFlags::from_year_mod_400(year_mod_400 as i32);
  384|     69|        NaiveDate::from_ordinal_and_flags(year_div_400 * 400 + year_mod_400 as i32, ordinal, flags)
