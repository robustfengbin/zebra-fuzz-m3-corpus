 1454|      3|    pub(crate) const fn num_days_from_ce(&self) -> i32 {
 1455|       |        // we know this wouldn't overflow since year is limited to 1/2^13 of i32's full range.
 1456|      3|        let mut year = self.year() - 1;
 1457|      3|        let mut ndays = 0;
 1458|      3|        if year < 0 {
 1459|      0|            let excess = 1 + (-year) / 400;
 1460|      0|            year += excess * 400;
 1461|      0|            ndays -= excess * 146_097;
 1462|      3|        }
 1463|      3|        let div_100 = year / 100;
 1464|      3|        ndays += ((year * 1461) >> 2) - div_100 + (div_100 >> 2);
 1465|      3|        ndays + self.ordinal() as i32
 1466|      3|    }
_RNvMNtNtCs8jXVBPYSQuE_6chrono5naive4dateNtB2_9NaiveDate22from_ordinal_and_flags:
  130|     43|    const fn from_ordinal_and_flags(
  131|     43|        year: i32,
  132|     43|        ordinal: u32,
  133|     43|        flags: YearFlags,
  134|     43|    ) -> Option<NaiveDate> {
  135|     43|        if year < MIN_YEAR || year > MAX_YEAR {
  136|      0|            return None; // Out-of-range
  137|     43|        }
  138|     43|        if ordinal == 0 || ordinal > 366 {
  139|      0|            return None; // Invalid
  140|     43|        }
  141|     43|        debug_assert!(YearFlags::from_year(year).0 == flags.0);
  142|     43|        let yof = (year << 13) | (ordinal << 4) as i32 | flags.0 as i32;
  143|     43|        match yof & OL_MASK <= MAX_OL {
  144|     43|            true => Some(NaiveDate::from_yof(yof)),
  145|      0|            false => None, // Does not exist: Ordinal 366 in a common year.
  146|       |        }
  147|     43|    }
_RNvMNtNtCs8jXVBPYSQuE_6chrono5naive4dateNtB2_9NaiveDate25from_num_days_from_ce_opt:
  378|     43|    pub const fn from_num_days_from_ce_opt(days: i32) -> Option<NaiveDate> {
  379|     43|        let days = try_opt!(days.checked_add(365)); // make December 31, 1 BCE equal to day 0
  380|     43|        let year_div_400 = days.div_euclid(146_097);
  381|     43|        let cycle = days.rem_euclid(146_097);
  382|     43|        let (year_mod_400, ordinal) = cycle_to_yo(cycle as u32);
  383|     43|        let flags = YearFlags::from_year_mod_400(year_mod_400 as i32);
