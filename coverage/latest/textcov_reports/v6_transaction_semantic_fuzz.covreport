  364|  2.64M|        let (r5, carry) = adc(0, r5, carry);
  365|  2.64M|        let (r6, carry) = mac(r6, self.0[3], self.0[3], carry);
  366|  2.64M|        let (r7, _) = adc(0, r7, carry);
  367|       |
