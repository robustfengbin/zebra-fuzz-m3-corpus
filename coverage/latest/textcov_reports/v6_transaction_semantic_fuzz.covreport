  222|  1.53k|        t_ += inv(alpha) << 16; // = t
  223|       |                                // 1 == x2 * ROOT_OF_UNITY^(t_ << 8)
  224|  1.53k|        assert!(t_ < 0x1000000);
  225|  1.53k|        let alpha = x3 * self.g0[t_ & 0xFF] * self.g1[(t_ >> 8) & 0xFF] * self.g2[t_ >> 16];
  226|       |
  227|  1.53k|        t_ += inv(alpha) << 24; // = t << 1
  228|       |                                // 1 == x3 * ROOT_OF_UNITY^t_
  229|  1.53k|        t_ = (((t_ as u64) + 1) >> 1) as usize;
  230|  1.53k|        assert!(t_ <= 0x80000000);
