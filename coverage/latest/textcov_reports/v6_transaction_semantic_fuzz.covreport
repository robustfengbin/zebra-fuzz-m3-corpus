  358|  1.54M|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  359|  1.54M|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  360|  1.54M|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  361|  1.54M|        let (r4, carry2) = adc(r4, 0, carry);
  362|       |
  363|  1.54M|        let k = r1.wrapping_mul(INV);
  364|  1.54M|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  365|  1.54M|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  366|  1.54M|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  367|  1.54M|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  368|  1.54M|        let (r5, carry2) = adc(r5, carry2, carry);
  369|       |
  370|  1.54M|        let k = r2.wrapping_mul(INV);
  371|  1.54M|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  372|  1.54M|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  373|  1.54M|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  374|  1.54M|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  375|  1.54M|        let (r6, carry2) = adc(r6, carry2, carry);
  376|       |
  377|  1.54M|        let k = r3.wrapping_mul(INV);
  378|  1.54M|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  379|  1.54M|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  380|  1.54M|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  381|  1.54M|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
