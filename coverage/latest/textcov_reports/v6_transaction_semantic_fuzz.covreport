  359|  7.79k|        let (r0, carry) = mac(0, self.0[0], self.0[0], 0);
  360|  7.79k|        let (r1, carry) = adc(0, r1, carry);
  361|  7.79k|        let (r2, carry) = mac(r2, self.0[1], self.0[1], carry);
  362|  7.79k|        let (r3, carry) = adc(0, r3, carry);
  363|  7.79k|        let (r4, carry) = mac(r4, self.0[2], self.0[2], carry);
  364|  7.79k|        let (r5, carry) = adc(0, r5, carry);
  365|  7.79k|        let (r6, carry) = mac(r6, self.0[3], self.0[3], carry);
  366|  7.79k|        let (r7, _) = adc(0, r7, carry);
  367|       |
  368|  7.79k|        Scalar::montgomery_reduce(r0, r1, r2, r3, r4, r5, r6, r7)
  369|  7.79k|    }
