  341|  17.7k|    pub const fn square(&self) -> Scalar {
  342|  17.7k|        let (r1, carry) = mac(0, self.0[0], self.0[1], 0);
  343|  17.7k|        let (r2, carry) = mac(0, self.0[0], self.0[2], carry);
  344|  17.7k|        let (r3, r4) = mac(0, self.0[0], self.0[3], carry);
  345|       |
