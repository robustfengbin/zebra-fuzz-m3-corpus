  342|  3.33k|    const fn montgomery_reduce(
  343|  3.33k|        r0: u64,
  344|  3.33k|        r1: u64,
  345|  3.33k|        r2: u64,
  346|  3.33k|        r3: u64,
  347|  3.33k|        r4: u64,
  348|  3.33k|        r5: u64,
  349|  3.33k|        r6: u64,
  350|  3.33k|        r7: u64,
  351|  3.33k|    ) -> Self {
  352|       |        // The Montgomery reduction here is based on Algorithm 14.32 in
  353|       |        // Handbook of Applied Cryptography
  354|       |        // <http://cacr.uwaterloo.ca/hac/about/chap14.pdf>.
  355|       |
  356|  3.33k|        let k = r0.wrapping_mul(INV);
  357|  3.33k|        let (_, carry) = mac(r0, k, MODULUS.0[0], 0);
  358|  3.33k|        let (r1, carry) = mac(r1, k, MODULUS.0[1], carry);
  359|  3.33k|        let (r2, carry) = mac(r2, k, MODULUS.0[2], carry);
  360|  3.33k|        let (r3, carry) = mac(r3, k, MODULUS.0[3], carry);
  361|  3.33k|        let (r4, carry2) = adc(r4, 0, carry);
  362|       |
  363|  3.33k|        let k = r1.wrapping_mul(INV);
  364|  3.33k|        let (_, carry) = mac(r1, k, MODULUS.0[0], 0);
  365|  3.33k|        let (r2, carry) = mac(r2, k, MODULUS.0[1], carry);
  366|  3.33k|        let (r3, carry) = mac(r3, k, MODULUS.0[2], carry);
  367|  3.33k|        let (r4, carry) = mac(r4, k, MODULUS.0[3], carry);
  368|  3.33k|        let (r5, carry2) = adc(r5, carry2, carry);
  369|       |
  370|  3.33k|        let k = r2.wrapping_mul(INV);
  371|  3.33k|        let (_, carry) = mac(r2, k, MODULUS.0[0], 0);
  372|  3.33k|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  373|  3.33k|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  374|  3.33k|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  375|  3.33k|        let (r6, carry2) = adc(r6, carry2, carry);
  376|       |
  377|  3.33k|        let k = r3.wrapping_mul(INV);
  378|  3.33k|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  379|  3.33k|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  380|  3.33k|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  381|  3.33k|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  382|  3.33k|        let (r7, _) = adc(r7, carry2, carry);
  383|       |
  384|       |        // Result may be within MODULUS of the correct value
  385|  3.33k|        (&Fp([r4, r5, r6, r7])).sub(&MODULUS)
  386|  3.33k|    }
