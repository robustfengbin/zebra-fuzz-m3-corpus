  310|  1.74k|    pub const fn square(&self) -> Fp {
  311|  1.74k|        let (r1, carry) = mac(0, self.0[0], self.0[1], 0);
  312|  1.74k|        let (r2, carry) = mac(0, self.0[0], self.0[2], carry);
  313|  1.74k|        let (r3, r4) = mac(0, self.0[0], self.0[3], carry);
  314|       |
  315|  1.74k|        let (r3, carry) = mac(r3, self.0[1], self.0[2], 0);
  316|  1.74k|        let (r4, r5) = mac(r4, self.0[1], self.0[3], carry);
  317|       |
  318|  1.74k|        let (r5, r6) = mac(r5, self.0[2], self.0[3], 0);
  319|       |
  320|  1.74k|        let r7 = r6 >> 63;
