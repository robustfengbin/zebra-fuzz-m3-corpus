  418|  3.35k|    pub const fn sub(&self, rhs: &Self) -> Self {
  419|  3.35k|        let (d0, borrow) = sbb(self.0[0], rhs.0[0], 0);
  420|  3.35k|        let (d1, borrow) = sbb(self.0[1], rhs.0[1], borrow);
  421|  3.35k|        let (d2, borrow) = sbb(self.0[2], rhs.0[2], borrow);
  422|  3.35k|        let (d3, borrow) = sbb(self.0[3], rhs.0[3], borrow);
