  322|  1.74k|        let r5 = (r5 << 1) | (r4 >> 63);
  323|  1.74k|        let r4 = (r4 << 1) | (r3 >> 63);
  324|  1.74k|        let r3 = (r3 << 1) | (r2 >> 63);
  325|  1.74k|        let r2 = (r2 << 1) | (r1 >> 63);
  326|  1.74k|        let r1 = r1 << 1;
  327|       |
  328|  1.74k|        let (r0, carry) = mac(0, self.0[0], self.0[0], 0);
  329|  1.74k|        let (r1, carry) = adc(0, r1, carry);
  330|  1.74k|        let (r2, carry) = mac(r2, self.0[1], self.0[1], carry);
  331|  1.74k|        let (r3, carry) = adc(0, r3, carry);
  332|  1.74k|        let (r4, carry) = mac(r4, self.0[2], self.0[2], carry);
  333|  1.74k|        let (r5, carry) = adc(0, r5, carry);
  334|  1.74k|        let (r6, carry) = mac(r6, self.0[3], self.0[3], carry);
  335|  1.74k|        let (r7, _) = adc(0, r7, carry);
  336|       |
  337|  1.74k|        Fp::montgomery_reduce(r0, r1, r2, r3, r4, r5, r6, r7)
  338|  1.74k|    }
