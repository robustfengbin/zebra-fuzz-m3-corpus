  185|      7|    pub fn sqrt_alt(&self, u: &F) -> (Choice, F) {
  186|      7|        let v = u.pow_by_t_minus1_over2();
  187|      7|        let uv = *u * v;
  188|       |
  189|      7|        let res = self.sqrt_common(&uv, &v);
  190|       |
  191|      7|        let sq = res.square();
  192|      7|        let is_square = (sq - u).is_zero();
  193|      7|        let is_nonsquare = (sq - F::ROOT_OF_UNITY * u).is_zero();
  194|      7|        assert!(bool::from(u.is_zero() | (is_square ^ is_nonsquare)));
  195|       |
