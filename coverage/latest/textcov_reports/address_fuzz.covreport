  557|  19.5k|        let (r0, carry) = mac(0, self.0[0], rhs.0[0], 0);
  558|  19.5k|        let (r1, carry) = mac(0, self.0[0], rhs.0[1], carry);
  559|  19.5k|        let (r2, carry) = mac(0, self.0[0], rhs.0[2], carry);
  560|  19.5k|        let (r3, r4) = mac(0, self.0[0], rhs.0[3], carry);
  561|       |
