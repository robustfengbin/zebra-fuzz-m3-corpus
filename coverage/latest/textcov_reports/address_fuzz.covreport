  536|  44.7k|        let (r3, carry) = mac(r3, k, MODULUS.0[1], carry);
  537|  44.7k|        let (r4, carry) = mac(r4, k, MODULUS.0[2], carry);
  538|  44.7k|        let (r5, carry) = mac(r5, k, MODULUS.0[3], carry);
  539|  44.7k|        let (r6, carry2) = adc(r6, carry2, carry);
  540|       |
  541|  44.7k|        let k = r3.wrapping_mul(INV);
  542|  44.7k|        let (_, carry) = mac(r3, k, MODULUS.0[0], 0);
  543|  44.7k|        let (r4, carry) = mac(r4, k, MODULUS.0[1], carry);
  544|  44.7k|        let (r5, carry) = mac(r5, k, MODULUS.0[2], carry);
  545|  44.7k|        let (r6, carry) = mac(r6, k, MODULUS.0[3], carry);
  546|  44.7k|        let (r7, _) = adc(r7, carry2, carry);
