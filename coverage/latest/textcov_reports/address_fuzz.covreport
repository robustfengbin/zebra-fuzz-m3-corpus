  408|     14|    pub fn invert(&self) -> CtOption<Self> {
  409|       |        #[inline(always)]
  410|       |        fn square_assign_multi(n: &mut Scalar, num_times: usize) {
  411|       |            for _ in 0..num_times {
  412|       |                *n = n.square();
  413|       |            }
  414|       |        }
  415|       |        // found using https://github.com/kwantam/addchain
  416|     14|        let mut t0 = self.square();
  417|     14|        let mut t1 = t0 * self;
  418|     14|        let mut t16 = t0.square();
  419|     14|        let mut t6 = t16.square();
  420|     14|        let mut t5 = t6 * t0;
  421|     14|        t0 = t6 * t16;
  422|     14|        let mut t12 = t5 * t16;
  423|     14|        let mut t2 = t6.square();
  424|     14|        let mut t7 = t5 * t6;
