_RNvMsa_NtCsjpkeS12E7YP_9bls12_3816scalarNtB5_6Scalar10from_bytes:
  256|     14|    pub fn from_bytes(bytes: &[u8; 32]) -> CtOption<Scalar> {
  257|     14|        let mut tmp = Scalar([0, 0, 0, 0]);
  258|       |
  259|     14|        tmp.0[0] = u64::from_le_bytes(<[u8; 8]>::try_from(&bytes[0..8]).unwrap());
  260|     14|        tmp.0[1] = u64::from_le_bytes(<[u8; 8]>::try_from(&bytes[8..16]).unwrap());
  261|     14|        tmp.0[2] = u64::from_le_bytes(<[u8; 8]>::try_from(&bytes[16..24]).unwrap());
  262|     14|        tmp.0[3] = u64::from_le_bytes(<[u8; 8]>::try_from(&bytes[24..32]).unwrap());
  263|       |
  264|       |        // Try to subtract the modulus
  265|     14|        let (_, borrow) = sbb(tmp.0[0], MODULUS.0[0], 0);
  266|     14|        let (_, borrow) = sbb(tmp.0[1], MODULUS.0[1], borrow);
  267|     14|        let (_, borrow) = sbb(tmp.0[2], MODULUS.0[2], borrow);
  268|     14|        let (_, borrow) = sbb(tmp.0[3], MODULUS.0[3], borrow);
  269|       |
  270|       |        // If the element is smaller than MODULUS then the
  271|       |        // subtraction will underflow, producing a borrow value
  272|       |        // of 0xffff...ffff. Otherwise, it'll be zero.
  273|     14|        let is_some = (borrow as u8) & 1;
  274|       |
  275|       |        // Convert to Montgomery form by computing
  276|       |        // (a.R^0 * R^2) / R = a.R
  277|     14|        tmp *= &R2;
  278|       |
  279|     14|        CtOption::new(tmp, Choice::from(is_some))
  280|     14|    }
