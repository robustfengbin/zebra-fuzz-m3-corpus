  427|  3.35k|        let (d1, carry) = adc(d1, MODULUS.0[1] & borrow, carry);
  428|  3.35k|        let (d2, carry) = adc(d2, MODULUS.0[2] & borrow, carry);
  429|  3.35k|        let (d3, _) = adc(d3, MODULUS.0[3] & borrow, carry);
  430|       |
