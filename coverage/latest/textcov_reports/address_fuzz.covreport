   18|     14|pub fn sqrt_tonelli_shanks<F: PrimeField, S: AsRef<[u64]>>(f: &F, tm1d2: S) -> CtOption<F> {
   19|       |    // This is a constant-time version of https://eprint.iacr.org/2012/685.pdf (page 12,
   20|       |    // algorithm 5). Steps 2-5 of the algorithm are omitted because they are only needed
   21|       |    // to detect non-square input; it is more efficient to do that by checking at the end
   22|       |    // whether the square of the result is the input.
   23|       |
   24|       |    // w = self^((t - 1) // 2)
   25|     14|    let w = f.pow_vartime(tm1d2);
   26|       |
   27|     14|    let mut v = F::S;
   28|     14|    let mut x = w * f;
   29|     14|    let mut b = x * w;
   30|       |
   31|       |    // Initialize z as the 2^S root of unity.
   32|     14|    let mut z = F::ROOT_OF_UNITY;
   33|       |
   34|    448|    for max_v in (1..=F::S).rev() {
   35|    448|        let mut k = 1;
   36|    448|        let mut b2k = b.square();
   37|    448|        let mut j_less_than_v: Choice = 1.into();
   38|       |
   39|       |        // This loop has three phases based on the value of k for algorithm 5:
   40|       |        // - for j <= k, we square b2k in order to calculate b^{2^k}.
   41|       |        // - for k < j <= v, we square z in order to calculate ω.
   42|       |        // - for j > v, we do nothing.
   43|  6.51k|        for j in 2..max_v {
   44|  6.51k|            let b2k_is_one = b2k.ct_eq(&F::ONE);
   45|  6.51k|            let squared = F::conditional_select(&b2k, &z, b2k_is_one).square();
   46|  6.51k|            b2k = F::conditional_select(&squared, &b2k, b2k_is_one);
   47|  6.51k|            let new_z = F::conditional_select(&z, &squared, b2k_is_one);
   48|  6.51k|            j_less_than_v &= !j.ct_eq(&v);
   49|  6.51k|            k = u32::conditional_select(&j, &k, b2k_is_one);
   50|  6.51k|            z = F::conditional_select(&z, &new_z, j_less_than_v);
   51|  6.51k|        }
   52|       |
   53|    448|        let result = x * z;
   54|    448|        x = F::conditional_select(&result, &x, b.ct_eq(&F::ONE));
   55|    448|        z = z.square();
   56|    448|        b *= z;
   57|    448|        v = k;
   58|       |    }
   59|       |
   60|     14|    CtOption::new(
   61|     14|        x,
   62|     14|        (x * x).ct_eq(f), // Only return Some if it's the square root.
   63|       |    )
   64|     14|}

