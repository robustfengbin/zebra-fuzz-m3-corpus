  600|  12.4k|    pub const fn add(&self, rhs: &Self) -> Self {
  601|  12.4k|        let (d0, carry) = adc(self.0[0], rhs.0[0], 0);
  602|  12.4k|        let (d1, carry) = adc(self.0[1], rhs.0[1], carry);
  603|  12.4k|        let (d2, carry) = adc(self.0[2], rhs.0[2], carry);
