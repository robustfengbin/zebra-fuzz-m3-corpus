  436|     14|        let t13 = t11 * t12;
  437|     14|        t12 = t11 * t17;
  438|     14|        t15 *= &t12;
  439|     14|        t16 *= &t15;
  440|     14|        t3 *= &t16;
  441|     14|        t17 *= &t3;
  442|     14|        t0 *= &t17;
  443|     14|        t6 *= &t0;
  444|     14|        t2 *= &t6;
  445|     14|        square_assign_multi(&mut t0, 8);
