   69|      1|    pub fn new(hash_xor: u32, hash_mod: usize) -> Self {
   70|       |        use alloc::vec;
   71|       |
   72|      1|        let hasher = SqrtHasher {
   73|      1|            hash_xor,
   74|      1|            hash_mod,
   75|      1|            marker: PhantomData,
   76|      1|        };
   77|       |
   78|      1|        let mut gtab = (0..4).scan(F::ROOT_OF_UNITY, |gi, _| {
   79|       |            // gi == ROOT_OF_UNITY^(256^i)
   80|       |            let gtab_i: Vec<F> = (0..256)
   81|       |                .scan(F::ONE, |acc, _| {
   82|       |                    let res = *acc;
   83|       |                    *acc *= *gi;
   84|       |                    Some(res)
   85|       |                })
   86|       |                .collect();
   87|       |            *gi = gtab_i[255] * *gi;
   88|       |            Some(gtab_i)
   89|       |        });
   90|      1|        let gtab_0 = gtab.next().unwrap();
   91|      1|        let gtab_1 = gtab.next().unwrap();
   92|      1|        let gtab_2 = gtab.next().unwrap();
   93|      1|        let mut gtab_3 = gtab.next().unwrap();
   94|      1|        assert_eq!(gtab.next(), None);
   95|       |
   96|       |        // Now invert gtab[3].
   97|      1|        let mut inv: Vec<u8> = vec![1; hash_mod];
   98|    256|        for (j, gtab_3_j) in gtab_3.iter().enumerate() {
   99|    256|            let hash = hasher.hash(gtab_3_j);
  100|       |            // 1 is the last value to be assigned, so this ensures there are no collisions.
  101|    256|            assert!(inv[hash] == 1);
  102|    256|            inv[hash] = ((256 - j) & 0xFF) as u8;
  103|       |        }
  104|       |
  105|      1|        gtab_3.truncate(129);
  106|       |
  107|      1|        SqrtTables::<F> {
  108|      1|            hasher,
  109|      1|            inv,
  110|      1|            g0: gtab_0.into_boxed_slice().try_into().unwrap(),
  111|      1|            g1: gtab_1.into_boxed_slice().try_into().unwrap(),
  112|      1|            g2: gtab_2.into_boxed_slice().try_into().unwrap(),
  113|      1|            g3: gtab_3.into_boxed_slice().try_into().unwrap(),
  114|      1|        }
  115|      1|    }
