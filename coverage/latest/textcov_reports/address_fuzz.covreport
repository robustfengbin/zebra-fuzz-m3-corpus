  449|      7|    pub const fn neg(&self) -> Self {
  450|       |        // Subtract `self` from `MODULUS` to negate. Ignore the final
  451|       |        // borrow because it cannot underflow; self is guaranteed to
  452|       |        // be in the field.
  453|      7|        let (d0, borrow) = sbb(MODULUS.0[0], self.0[0], 0);
  454|      7|        let (d1, borrow) = sbb(MODULUS.0[1], self.0[1], borrow);
  455|      7|        let (d2, borrow) = sbb(MODULUS.0[2], self.0[2], borrow);
  456|      7|        let (d3, _) = sbb(MODULUS.0[3], self.0[3], borrow);
  457|       |
  458|       |        // `tmp` could be `MODULUS` if `self` was zero. Create a mask that is
  459|       |        // zero if `self` was zero, and `u64::max_value()` if self was nonzero.
  460|      7|        let mask = (((self.0[0] | self.0[1] | self.0[2] | self.0[3]) == 0) as u64).wrapping_sub(1);
  461|       |
  462|      7|        Fp([d0 & mask, d1 & mask, d2 & mask, d3 & mask])
  463|      7|    }
