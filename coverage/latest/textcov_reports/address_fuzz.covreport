  415|     14|pub unsafe fn compress1_loop(
  416|     14|    input: &[u8],
  417|     14|    words: &mut [Word; 8],
  418|     14|    mut count: Count,
  419|     14|    last_node: LastNode,
  420|     14|    finalize: Finalize,
  421|     14|    stride: Stride,
  422|     14|) {
  423|       |    unsafe {
  424|     14|        input_debug_asserts(input, finalize);
  425|       |
  426|     14|        let mut local_words = *words;
  427|       |
  428|     14|        let mut fin_offset = input.len().saturating_sub(1);
  429|     14|        fin_offset -= fin_offset % stride.padded_blockbytes();
  430|     14|        let mut buf = [0; BLOCKBYTES];
  431|     14|        let (fin_block, fin_len, _) = final_block(input, fin_offset, &mut buf, stride);
  432|     14|        let fin_last_block = flag_word(finalize.yes());
  433|     14|        let fin_last_node = flag_word(finalize.yes() && last_node.yes());
  434|       |
  435|     14|        let mut offset = 0;
  436|       |        loop {
  437|       |            let block;
  438|       |            let count_delta;
  439|       |            let last_block;
  440|       |            let last_node;
  441|     14|            if offset == fin_offset {
  442|     14|                block = fin_block;
  443|     14|                count_delta = fin_len;
  444|     14|                last_block = fin_last_block;
  445|     14|                last_node = fin_last_node;
  446|     14|            } else {
  447|      0|                // This unsafe cast avoids bounds checks. There's guaranteed to be
  448|      0|                // enough input because `offset < fin_offset`.
  449|      0|                block = &*(input.as_ptr().add(offset) as *const [u8; BLOCKBYTES]);
  450|      0|                count_delta = BLOCKBYTES;
  451|      0|                last_block = flag_word(false);
  452|      0|                last_node = flag_word(false);
  453|      0|            };
  454|       |
  455|     14|            count = count.wrapping_add(count_delta as Count);
  456|     14|            compress_block(block, &mut local_words, count, last_block, last_node);
  457|       |
  458|       |            // Check for termination before bumping the offset, to avoid overflow.
  459|     14|            if offset == fin_offset {
