  377|      5|                INITIAL_STATE,
  378|      5|                (INITIAL_STATE - REF_ONE) & !JOIN_INTEREST,
  379|      5|                Release,
  380|      5|                Relaxed,
  381|      5|            )
  382|      5|            .map(|_| ())
  383|      5|            .map_err(|_| ())
  384|      5|    }
