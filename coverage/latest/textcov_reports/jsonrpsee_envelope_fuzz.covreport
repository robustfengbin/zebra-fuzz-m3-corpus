  338|      2|          [](const ConfigOptions& /*opts*/, const std::string& /*name*/,
  339|      2|             const std::string& value, void* addr) {
  340|       |            // A workaround to fix a bug in 6.10, 6.11, 6.12, 6.13
  341|       |            // and 6.14. The bug will write out 8 bytes to OPTIONS file from the
  342|       |            // starting address of BlockBasedTableOptions.read_amp_bytes_per_bit
