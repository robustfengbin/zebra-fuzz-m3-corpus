  447|    254|pub fn block_subsidy(height: Height, net: &Network) -> Result<Amount<NonNegative>, SubsidyError> {
  448|    254|    let Some(halving_div) = halving_divisor(height, net) else {
  449|      1|        return Ok(Amount::zero());
  450|       |    };
  451|       |
  452|    253|    let slow_start_interval = net.slow_start_interval();
  453|       |
  454|       |    // The `floor` fn used in the spec is implicit in Rust's division of primitive integer types.
  455|       |
  456|    253|    let amount = if height < slow_start_interval {
  457|    228|        let slow_start_rate = MAX_BLOCK_SUBSIDY / u64::from(slow_start_interval);
  458|       |
  459|    228|        if height < net.slow_start_shift() {
  460|    228|            slow_start_rate * u64::from(height)
  461|       |        } else {
  462|      0|            slow_start_rate * (u64::from(height) + 1)
  463|       |        }
  464|       |    } else {
  465|     25|        let base_subsidy = if NetworkUpgrade::current(net, height) < NetworkUpgrade::Blossom {
  466|      3|            MAX_BLOCK_SUBSIDY
  467|       |        } else {
  468|     22|            MAX_BLOCK_SUBSIDY / u64::from(BLOSSOM_POW_TARGET_SPACING_RATIO)
  469|       |        };
  470|       |
  471|     25|        base_subsidy / halving_div
  472|       |    };
  473|       |
  474|    253|    Ok(Amount::try_from(amount)?)
  475|    254|}
