  341|    196|    expected_block_subsidy: Amount<NonNegative>,
  342|    196|) -> Result<HashMap<FundingStreamReceiver, Amount<NonNegative>>, amount::Error> {
  343|    196|    let mut results = HashMap::new();
  344|       |
  345|    196|    if expected_block_subsidy.is_zero() {
  346|     88|        return Ok(results);
  347|    108|    }
  348|       |
  349|    108|    if NetworkUpgrade::current(network, height) >= NetworkUpgrade::Canopy {
  350|     36|        let funding_streams = network.funding_streams(height);
  351|     36|        if let Some(funding_streams) = funding_streams {
  352|     92|            for (&receiver, recipient) in funding_streams.recipients() {
  353|       |                // - Spec equation: `fs.value = floor(block_subsidy(height)*(fs.numerator/fs.denominator))`:
  354|       |                //   https://zips.z.cash/protocol/protocol.pdf#subsidies
  355|       |                // - In Rust, "integer division rounds towards zero":
  356|       |                //   https://doc.rust-lang.org/stable/reference/expressions/operator-expr.html#arithmetic-and-logical-binary-operators
  357|       |                //   This is the same as `floor()`, because these numbers are all positive.
  358|     92|                let amount_value = ((expected_block_subsidy * recipient.numerator())?
  359|      0|                    / FUNDING_STREAM_RECEIVER_DENOMINATOR)?;
  360|       |
  361|     92|                results.insert(receiver, amount_value);
  362|       |            }
  363|      4|        }
  364|     72|    }
  365|       |
  366|    108|    Ok(results)
  367|    196|}
_RNvNtNtNtCs2qdhHbQ3r3c_11zebra_chain10parameters7network7subsidy7halving:
  418|    450|pub fn halving(height: Height, network: &Network) -> u32 {
  419|    450|    let slow_start_shift = network.slow_start_shift();
  420|    450|    let blossom_height = NetworkUpgrade::Blossom
  421|    450|        .activation_height(network)
  422|    450|        .expect("blossom activation height should be available");
  423|       |
  424|    450|    let halving_index = if height < slow_start_shift {
  425|    380|        0
  426|     70|    } else if height < blossom_height {
  427|      5|        let pre_blossom_height = height - slow_start_shift;
  428|      5|        pre_blossom_height / network.pre_blossom_halving_interval()
  429|       |    } else {
  430|     65|        let pre_blossom_height = blossom_height - slow_start_shift;
  431|     65|        let scaled_pre_blossom_height =
  432|     65|            pre_blossom_height * HeightDiff::from(BLOSSOM_POW_TARGET_SPACING_RATIO);
  433|       |
  434|     65|        let post_blossom_height = height - blossom_height;
  435|       |
  436|     65|        (scaled_pre_blossom_height + post_blossom_height) / network.post_blossom_halving_interval()
  437|       |    };
  438|       |
  439|    450|    halving_index
  440|    450|        .try_into()
  441|    450|        .expect("already checked for negatives")
