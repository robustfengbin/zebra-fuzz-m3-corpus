 3059|     12|    async fn generate(&self, num_blocks: u32) -> Result<Vec<Hash>> {
 3060|       |        let mut rpc = self.clone();
 3061|       |        let network = self.network.clone();
 3062|       |
 3063|       |        if !network.disable_pow() {
