  423|       |
  424|    565|    let halving_index = if height < slow_start_shift {
  425|    465|        0
  426|    100|    } else if height < blossom_height {
  427|      5|        let pre_blossom_height = height - slow_start_shift;
  428|      5|        pre_blossom_height / network.pre_blossom_halving_interval()
  429|       |    } else {
  430|     95|        let pre_blossom_height = blossom_height - slow_start_shift;
  431|     95|        let scaled_pre_blossom_height =
  432|     95|            pre_blossom_height * HeightDiff::from(BLOSSOM_POW_TARGET_SPACING_RATIO);
  433|       |
  434|     95|        let post_blossom_height = height - blossom_height;
  435|       |
  436|     95|        (scaled_pre_blossom_height + post_blossom_height) / network.post_blossom_halving_interval()
  437|       |    };
  438|       |
  439|    565|    halving_index
  440|    565|        .try_into()
  441|    565|        .expect("already checked for negatives")
  442|    565|}
