   84|    159|        .get(..len)
   85|    159|        .ok_or(parse_err("Coinbase script too short"))?
   86|    159|        != pattern::push_num(h).to_bytes().as_slice()
   87|       |    {
   88|     12|        return Err(parse_err("Non-canonical coinbase height encoding"));
   89|    147|    }
   90|       |
   91|    147|    let h = u32::try_from(h).map_err(|_| parse_err("Negative coinbase height"))?;
   92|    146|    let height =
