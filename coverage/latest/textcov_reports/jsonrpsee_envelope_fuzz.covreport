   84|    165|        .get(..len)
   85|    165|        .ok_or(parse_err("Coinbase script too short"))?
   86|    165|        != pattern::push_num(h).to_bytes().as_slice()
   87|       |    {
   88|     12|        return Err(parse_err("Non-canonical coinbase height encoding"));
   89|    153|    }
   90|       |
   91|    153|    let h = u32::try_from(h).map_err(|_| parse_err("Negative coinbase height"))?;
   92|    152|    let height =
   93|    152|        Height::try_from(h).map_err(|_| parse_err("Coinbase height exceeds Height::MAX"))?;
