  453|       |
  454|       |    // The `floor` fn used in the spec is implicit in Rust's division of primitive integer types.
  455|       |
  456|    314|    let amount = if height < slow_start_interval {
  457|    279|        let slow_start_rate = MAX_BLOCK_SUBSIDY / u64::from(slow_start_interval);
  458|       |
  459|    279|        if height < net.slow_start_shift() {
  460|    279|            slow_start_rate * u64::from(height)
  461|       |        } else {
  462|      0|            slow_start_rate * (u64::from(height) + 1)
  463|       |        }
  464|       |    } else {
  465|     35|        let base_subsidy = if NetworkUpgrade::current(net, height) < NetworkUpgrade::Blossom {
  466|      3|            MAX_BLOCK_SUBSIDY
  467|       |        } else {
  468|     32|            MAX_BLOCK_SUBSIDY / u64::from(BLOSSOM_POW_TARGET_SPACING_RATIO)
  469|       |        };
  470|       |
  471|     35|        base_subsidy / halving_div
  472|       |    };
  473|       |
  474|    314|    Ok(Amount::try_from(amount)?)
  475|    315|}
