  447|    315|pub fn block_subsidy(height: Height, net: &Network) -> Result<Amount<NonNegative>, SubsidyError> {
  448|    315|    let Some(halving_div) = halving_divisor(height, net) else {
  449|      1|        return Ok(Amount::zero());
  450|       |    };
  451|       |
