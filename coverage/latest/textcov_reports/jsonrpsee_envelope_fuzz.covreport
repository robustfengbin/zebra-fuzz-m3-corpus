  358|    140|                let amount_value = ((expected_block_subsidy * recipient.numerator())?
  359|      0|                    / FUNDING_STREAM_RECEIVER_DENOMINATOR)?;
  360|       |
  361|    140|                results.insert(receiver, amount_value);
  362|       |            }
  363|      4|        }
  364|     86|    }
