  210|     31|                reader.read_32_bytes()?.into(),
  211|       |            ],
  212|       |            // Types are `NoteCommit^{Sprout}.Output`, i.e. `B^{ℓ^{Sprout}_{Merkle}}`,
  213|       |            // i.e. 32 bytes. https://zips.z.cash/protocol/protocol.pdf#abstractcommit
  214|       |            commitments: [
