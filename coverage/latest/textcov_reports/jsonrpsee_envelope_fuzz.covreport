  449|      4|                                  char item_separator = ';') {
  450|      4|    OptionTypeInfo info(_offset, OptionType::kStringMap, _verification, _flags);
  451|      4|    info.SetParseFunc(
  452|      4|        [kv_separator, item_separator](const ConfigOptions&, const std::string&,
  453|      4|                                       const std::string& value, void* addr) {
  454|      4|          std::map<std::string, std::string> map;
  455|      4|          Status s;
  456|      4|          for (size_t start = 0, end = 0;
  457|      4|               s.ok() && start < value.size() && end != std::string::npos;
  458|      4|               start = end + 1) {
  459|      4|            std::string token;
  460|      4|            s = OptionTypeInfo::NextToken(value, item_separator, start, &end,
  461|      4|                                          &token);
  462|      4|            if (s.ok() && !token.empty()) {
  463|      4|              size_t pos = token.find(kv_separator);
  464|      4|              assert(pos != std::string::npos);
  465|      4|              std::string k = token.substr(0, pos);
  466|      4|              std::string v = token.substr(pos + 1);
  467|      4|              std::string decoded_key;
  468|      4|              std::string decoded_value;
  469|      4|              (Slice(k)).DecodeHex(&decoded_key);
  470|      4|              (Slice(v)).DecodeHex(&decoded_value);
  471|      4|              map.emplace(std::move(decoded_key), std::move(decoded_value));
  472|      4|            }
  473|      4|          }
  474|      4|          if (s.ok()) {
  475|      4|            *(static_cast<std::map<std::string, std::string>*>(addr)) = map;
  476|      4|          }
  477|      4|          return s;
  478|      4|        });
  479|      4|    info.SetSerializeFunc(
  480|      4|        [kv_separator, item_separator](const ConfigOptions&, const std::string&,
  481|      4|                                       const void* addr, std::string* value) {
  482|      4|          const auto map =
  483|      4|              static_cast<const std::map<std::string, std::string>*>(addr);
  484|      4|          value->append("{");
  485|      4|          for (const auto& entry : *map) {
  486|      4|            value->append(Slice(entry.first).ToString(true));
  487|      4|            *value += kv_separator;
  488|      4|            value->append(Slice(entry.second).ToString(true));
  489|      4|            *value += item_separator;
  490|      4|          }
  491|      4|          value->append("}");
  492|      4|          return Status::OK();
  493|      4|        });
