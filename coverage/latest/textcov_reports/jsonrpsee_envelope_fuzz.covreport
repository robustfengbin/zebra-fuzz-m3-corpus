 1514|    717|    fn set_complete(cell: &AtomicUsize) -> State {
 1515|       |        // This method is a compare-and-swap loop rather than a fetch-or like
 1516|       |        // other `set_$WHATEVER` methods on `State`. This is because we must
 1517|       |        // check if the state has been closed before setting the `VALUE_SENT`
 1518|       |        // bit.
 1519|       |        //
 1520|       |        // We don't want to set both the `VALUE_SENT` bit if the `CLOSED`
 1521|       |        // bit is already set, because `VALUE_SENT` will tell the receiver that
 1522|       |        // it's okay to access the inner `UnsafeCell`. Immediately after calling
 1523|       |        // `set_complete`, if the channel was closed, the sender will _also_
 1524|       |        // access the `UnsafeCell` to take the value back out, so if a
 1525|       |        // `poll_recv` or `try_recv` call is occurring concurrently, both
 1526|       |        // threads may try to access the `UnsafeCell` if we were to set the
 1527|       |        // `VALUE_SENT` bit on a closed channel.
 1528|    717|        let mut state = cell.load(Ordering::Relaxed);
 1529|       |        loop {
 1530|    717|            if State(state).is_closed() {
 1531|      0|                break;
 1532|    717|            }
 1533|       |            // TODO: This could be `Release`, followed by an `Acquire` fence *if*
 1534|       |            // the `RX_TASK_SET` flag is set. However, `loom` does not support
 1535|       |            // fences yet.
 1536|    717|            match cell.compare_exchange_weak(
 1537|    717|                state,
 1538|    717|                state | VALUE_SENT,
 1539|    717|                Ordering::AcqRel,
 1540|    717|                Ordering::Acquire,
 1541|    717|            ) {
 1542|    717|                Ok(_) => break,
 1543|      0|                Err(actual) => state = actual,
 1544|       |            }
 1545|       |        }
 1546|    717|        State(state)
