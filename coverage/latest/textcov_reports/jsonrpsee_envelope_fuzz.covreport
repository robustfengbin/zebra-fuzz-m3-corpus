 3114|       |                        None::<()>,
 3115|       |                    ));
 3116|       |                }
 3117|       |            }
 3118|       |
 3119|       |            block_hashes.push(GetBlockHashResponse(proposal_block.hash()));
 3120|       |        }
 3121|       |
 3122|       |        Ok(block_hashes)
 3123|     12|    }
