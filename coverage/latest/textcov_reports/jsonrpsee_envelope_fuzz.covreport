  462|  6.74k|    let payload = &data[2..];
  463|       |
  464|  6.74k|    let params_json = match params_kind {
  465|       |        0b00 => {
  466|       |            // Try to interpret as raw JSON; fall back to string literal.
  467|  5.15k|            match std::str::from_utf8(payload) {
  468|  5.12k|                Ok(s) if serde_json::from_str::<serde_json::Value>(s).is_ok() => s.to_string(),
  469|  1.16k|                Ok(s) => format!("[{}]", serde_json::Value::String(s.to_string())),
  470|     30|                Err(_) => "[]".to_string(),
  471|       |            }
  472|       |        }
  473|       |        0b01 => {
  474|    410|            let s = String::from_utf8_lossy(payload).into_owned();
  475|    410|            format!("[{}]", serde_json::Value::String(s))
  476|       |        }
  477|       |        0b10 => {
  478|       |            // Numeric param: 8-byte BE → i64 then JSON number. Wider
  479|       |            // surface for handlers that take Option<i32> / Option<u32>
  480|       |            // (getblockhash, getnetworksolps, etc.).
  481|     45|            let mut buf = [0u8; 8];
  482|    168|            for (i, b) in payload.iter().take(8).enumerate() {
  483|    168|                buf[i] = *b;
  484|    168|            }
