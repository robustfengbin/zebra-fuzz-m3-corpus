  535|    250|pub fn founders_reward(net: &Network, height: Height) -> Amount<NonNegative> {
  536|       |    // The founders reward is 20% of the block subsidy before the first halving, and 0 afterwards.
  537|       |    //
  538|       |    // On custom testnets, the first halving can occur later than Canopy, which causes an
  539|       |    // inconsistency in the definition of the founders reward, which should occur only before
  540|       |    // Canopy, so we check if Canopy is active as well.
  541|    250|    if halving(height, net) < 1 && NetworkUpgrade::current(net, height) < NetworkUpgrade::Canopy {
  542|    190|        block_subsidy(height, net)
  543|    190|            .map(|subsidy| subsidy.div_exact(5))
  544|    190|            .expect("block subsidy must be valid for founders rewards")
  545|       |    } else {
  546|     60|        Amount::zero()
  547|       |    }
  548|    250|}
