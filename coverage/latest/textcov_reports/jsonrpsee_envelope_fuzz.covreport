  113|       |        // the relatively larger ctrl_align:
  114|       |        //
  115|       |        // | capacity | buckets | bytes allocated | bytes per item |
  116|       |        // | -------- | ------- | --------------- | -------------- |
  117|       |        // |        3 |       4 |              36 | (Yikes!)  12.0 |
  118|       |        // |        7 |       8 |              40 | (Poor)     5.7 |
  119|       |        // |       14 |      16 |              48 |            3.4 |
  120|       |        // |       28 |      32 |              80 |            3.3 |
  121|       |        //
